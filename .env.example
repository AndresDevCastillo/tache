# Frontend Astro — variables disponibles en build-time.
# Las que empiezan con PUBLIC_ se exponen al cliente vía import.meta.env.
# Copiar a `.env` (no se commitea — está en .gitignore vía Astro).

# URL completa del endpoint POST del backend NestJS.
# Si se deja vacío, el formulario solo abre wa.me (sin enviar email).
PUBLIC_API_URL=https://api.tachetech.com/api/contact
