---
import { Icon } from 'astro-icon/components';
---

<section id="nosotros" class="section">
  <div class="container-pro">
    <!-- ¿Quiénes somos? -->
    <div class="mx-auto max-w-4xl text-center mb-16 md:mb-20">
      <span class="badge-eyebrow" data-reveal>Quiénes somos</span>
      <h2 class="h2 mt-5 text-slate-900" data-reveal data-reveal-delay="100">
        Una <span class="text-[#1d0cdf]">startup tecnológica</span> enfocada en hacer crecer tu negocio
      </h2>
      <p class="lead mt-6" data-reveal data-reveal-delay="200">
        Combinamos ingeniería de software, diseño moderno y automatización inteligente para entregar
        productos digitales que mueven la aguja. No vendemos horas: vendemos resultados medibles — más
        ventas, menos costos operativos o procesos que antes tomaban días y ahora minutos.
      </p>
    </div>

    <!-- Misión + Visión -->
    <div class="grid gap-6 md:gap-8 md:grid-cols-2 mb-16 md:mb-20">
      <article class="card" data-reveal>
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[#eef0ff] text-[#1d0cdf] ring-1 ring-[#1d0cdf]/10">
          <Icon name="tabler:target-arrow" class="h-6 w-6" />
        </div>
        <h3 class="mt-5 text-2xl font-bold text-slate-900">Misión</h3>
        <p class="mt-3 text-[16px] leading-relaxed text-slate-600">
          Impulsar el crecimiento de empresas mediante soluciones tecnológicas innovadoras, eficientes y
          adaptadas a sus necesidades reales.
        </p>
      </article>

      <article class="card" data-reveal data-reveal-delay="100">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[#eef0ff] text-[#1d0cdf] ring-1 ring-[#1d0cdf]/10">
          <Icon name="tabler:eye" class="h-6 w-6" />
        </div>
        <h3 class="mt-5 text-2xl font-bold text-slate-900">Visión</h3>
        <p class="mt-3 text-[16px] leading-relaxed text-slate-600">
          Ser una empresa líder en desarrollo tecnológico, reconocida por transformar negocios a través de
          la innovación digital.
        </p>
      </article>
    </div>

    <!-- Reconocimiento -->
    <article
      class="card mb-16 md:mb-20 border-[#1d0cdf]/15 bg-[#f7f8fc]"
      data-reveal
      data-reveal-delay="140"
    >
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#1d0cdf]">
        Reconocimiento
      </p>
      <h3 class="mt-3 text-2xl md:text-3xl font-bold text-slate-900">
        Ganadores del Programa Transformación Digital para MiPYMES
      </h3>
      <div class="mx-auto mt-6 w-full max-w-3xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-soft">
        <img
          src="/images/news/premio-transformacion-3.jpeg"
          alt="Equipo de Tache Technology recibiendo reconocimiento en la Cámara de Comercio de Montería."
          loading="lazy"
          decoding="async"
          width="1024"
          height="768"
          class="block h-auto w-full object-cover"
        />
      </div>
      <p class="mt-2 text-xs text-slate-500">
        Foto publicada por Chica Noticias en la cobertura del evento (13 de noviembre de 2024).
      </p>
      <p class="mt-4 text-[16px] leading-relaxed text-slate-600">
        El 13 de noviembre de 2024, Chica Noticias destacó a Tache Technology como ganador de la convocatoria
        de la Cámara de Comercio de Montería para fortalecer capacidades digitales empresariales.
      </p>
      <p class="mt-3 text-[16px] leading-relaxed text-slate-600">
        Nuestro equipo fue reconocido entre los mejores desarrolladores del programa, con premios de $5, $3 y
        $2 millones de pesos para impulsar soluciones tecnológicas en la región.
      </p>
      <a
        href="https://www.chicanoticias.com/2024/11/13/trasnformacion-comercio-digital/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary mt-6 inline-flex"
      >
        Ver noticia completa
        <Icon name="tabler:external-link" class="h-4 w-4" />
      </a>
    </article>

    <!-- Valores -->
    <div class="text-center mb-10">
      <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900" data-reveal>
        Los principios con los que trabajamos
      </h3>
    </div>

    <div class="grid gap-4 md:gap-5 md:grid-cols-3 lg:grid-cols-5">
      {
        [
          { icon: 'tabler:bulb', label: 'Innovación constante' },
          { icon: 'tabler:heart-handshake', label: 'Compromiso con el cliente' },
          { icon: 'tabler:award', label: 'Calidad y excelencia' },
          { icon: 'tabler:eye-check', label: 'Transparencia' },
          { icon: 'tabler:refresh', label: 'Adaptabilidad tecnológica' },
        ].map((value, idx) => (
          <div
            class="card flex flex-col items-center text-center"
            data-reveal
            data-reveal-delay={Math.min(idx * 80, 300).toString()}
          >
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-[#eef0ff] text-[#1d0cdf] ring-1 ring-[#1d0cdf]/10">
              <Icon name={value.icon} class="h-5 w-5" />
            </span>
            <p class="mt-4 text-sm font-semibold text-slate-900">{value.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
