---
import { Icon } from 'astro-icon/components';
---

<section id="nosotros" class="relative py-20 md:py-28 scroll-mt-[72px]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <!-- ¿Quiénes somos? -->
    <div class="mx-auto max-w-4xl text-center mb-16 md:mb-24">
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 dark:text-white"
        data-reveal
      >
        Una <span class="text-gradient">startup tecnológica</span> enfocada en hacer crecer tu negocio
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300" data-reveal data-reveal-delay="100">
        Combinamos ingeniería de software, diseño moderno y automatización inteligente para entregar
        productos digitales que mueven la aguja. No vendemos horas: vendemos resultados medibles, ya sea
        más ventas, menos costos operativos o procesos que antes tomaban días y ahora minutos.
      </p>
    </div>

    <!-- Misión + Visión -->
    <div class="grid gap-6 md:gap-8 md:grid-cols-2 mb-16 md:mb-20">
      <article class="card-glass" data-reveal>
        <div
          class="inline-flex h-12 w-12 items-center justify-center rounded-xl text-white shadow-lg"
          style="background-image: linear-gradient(135deg, #1d0cdf, #2563eb);"
        >
          <Icon name="tabler:target-arrow" class="h-6 w-6" />
        </div>
        <h3 class="mt-5 text-2xl font-bold text-slate-900 dark:text-white">Misión</h3>
        <p class="mt-3 text-[16px] leading-relaxed text-slate-600 dark:text-slate-300">
          Impulsar el crecimiento de empresas mediante soluciones tecnológicas innovadoras, eficientes y
          adaptadas a sus necesidades reales.
        </p>
      </article>

      <article class="card-glass" data-reveal data-reveal-delay="100">
        <div
          class="inline-flex h-12 w-12 items-center justify-center rounded-xl text-white shadow-lg"
          style="background-image: linear-gradient(135deg, #2563eb, #22d3ee);"
        >
          <Icon name="tabler:eye" class="h-6 w-6" />
        </div>
        <h3 class="mt-5 text-2xl font-bold text-slate-900 dark:text-white">Visión</h3>
        <p class="mt-3 text-[16px] leading-relaxed text-slate-600 dark:text-slate-300">
          Ser una empresa líder en desarrollo tecnológico, reconocida por transformar negocios a través de
          la innovación digital.
        </p>
      </article>
    </div>

    <!-- Valores -->
    <div class="text-center mb-12">
      <h3
        class="text-2xl md:text-3xl font-bold tracking-tight text-slate-900 dark:text-white"
        data-reveal
      >
        Los principios con los que trabajamos
      </h3>
    </div>

    <div class="grid gap-4 md:gap-5 md:grid-cols-3 lg:grid-cols-5">
      {
        [
          { icon: 'tabler:bulb', label: 'Innovación constante' },
          { icon: 'tabler:heart-handshake', label: 'Compromiso con el cliente' },
          { icon: 'tabler:award', label: 'Calidad y excelencia' },
          { icon: 'tabler:eye-check', label: 'Transparencia' },
          { icon: 'tabler:refresh', label: 'Adaptabilidad tecnológica' },
        ].map((value, idx) => (
          <div
            class="card-glass flex flex-col items-center text-center"
            data-reveal
            data-reveal-delay={Math.min(idx * 80, 300).toString()}
          >
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-slate-100 dark:bg-white/[0.05] text-blue-600 dark:text-cyan-300 ring-1 ring-slate-200 dark:ring-white/10">
              <Icon name={value.icon} class="h-5 w-5" />
            </span>
            <p class="mt-4 text-sm font-semibold text-slate-900 dark:text-white">{value.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
