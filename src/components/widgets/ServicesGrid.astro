---
import { Icon } from 'astro-icon/components';

export interface Service {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  /** Alias de eyebrow (compat) */
  tagline?: string;
  title?: string;
  subtitle?: string;
  items: Service[];
  cardCta?: string;
  /** Si es true, muestra 4 columnas en xl. Por defecto 3. */
  fourCols?: boolean;
  /** Enlace opcional "Ver todos los servicios →" arriba a la derecha / bajo subtítulo */
  allLink?: { text: string; href: string };
}

const {
  id = 'servicios',
  eyebrow,
  tagline,
  title = 'Servicios que transforman',
  subtitle = 'Soluciones tecnológicas diseñadas para mejorar la operación, presencia digital y crecimiento de tu empresa.',
  items,
  cardCta = 'Conocer más',
  fourCols = false,
  allLink,
} = Astro.props;

const label = eyebrow ?? tagline ?? 'Servicios';

const gridCols = fourCols
  ? 'md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'
  : 'md:grid-cols-2 lg:grid-cols-3';
---

<section id={id} class="section">
  <div class="container-pro">
    <div class="mx-auto max-w-3xl text-center mb-12 md:mb-16">
      {label && (
        <span class="badge-eyebrow" data-reveal>
          {label}
        </span>
      )}
      <h2 class="h2 mt-5 text-slate-900" data-reveal data-reveal-delay="100">
        {title}
      </h2>
      <p class="lead mt-5" data-reveal data-reveal-delay="200">
        {subtitle}
      </p>
      {allLink && (
        <a
          href={allLink.href}
          class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#1d0cdf] hover:text-[#1709b8]"
          data-reveal
          data-reveal-delay="300"
        >
          {allLink.text}
          <Icon name="tabler:arrow-right" class="h-4 w-4" />
        </a>
      )}
    </div>

    <div class:list={['grid gap-5 md:gap-6', gridCols]}>
      {
        items.map((service, idx) => (
          <article
            class="card group flex flex-col h-full"
            data-reveal
            data-reveal-delay={Math.min(((idx % 3) + 1) * 100, 300).toString()}
          >
            <div class="relative inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[#eef0ff] text-[#1d0cdf] ring-1 ring-[#1d0cdf]/10 transition-all duration-300 group-hover:bg-[#1d0cdf] group-hover:text-white group-hover:ring-[#1d0cdf]/40">
              <Icon name={service.icon} class="h-6 w-6" />
            </div>

            <h3 class="mt-5 text-lg md:text-xl font-semibold text-slate-900">{service.title}</h3>
            <p class="mt-3 text-[15px] leading-relaxed text-slate-600 flex-grow">{service.description}</p>

            {cardCta && (
              <a
                href={service.href || '/contacto'}
                class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#1d0cdf] transition-colors hover:text-[#1709b8]"
                aria-label={`${cardCta}: ${service.title}`}
              >
                {cardCta}
                <Icon
                  name="tabler:arrow-right"
                  class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
                />
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
