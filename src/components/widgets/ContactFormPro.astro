---
import { Icon } from 'astro-icon/components';

export interface Props {
  id?: string;
  /** Número WhatsApp en formato internacional sin '+' */
  whatsappNumber?: string;
  /** URL del backend NestJS para POST /contact. Si vacía, solo abre wa.me. */
  apiEndpoint?: string;
  /** Título de la sección */
  title?: string;
  subtitle?: string;
}

const {
  id = 'contacto',
  whatsappNumber = '573013745541',
  apiEndpoint = import.meta.env.PUBLIC_API_URL || '',
  title = 'Hablemos de tu proyecto',
  subtitle = 'Cuéntanos qué necesitas y te responderemos con una orientación clara para ayudarte a tomar la mejor decisión.',
} = Astro.props;
---

<section id={id} class="section bg-section">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center mb-12 md:mb-16">
      <span class="badge-eyebrow" data-reveal>Contacto</span>
      <h2 class="h2 mt-5 text-slate-900" data-reveal data-reveal-delay="100">{title}</h2>
      <p class="lead mt-5 max-w-2xl mx-auto" data-reveal data-reveal-delay="200">{subtitle}</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-12 lg:gap-10">
      <!-- Formulario -->
      <div class="lg:col-span-8" data-reveal>
        <form
          id="contact-form"
          class="rounded-3xl border border-slate-200 bg-white p-6 md:p-8 shadow-card space-y-5"
          data-whatsapp={whatsappNumber}
          data-endpoint={apiEndpoint}
          novalidate
          aria-describedby="cf-status"
        >
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="cf-name" class="block text-sm font-medium text-slate-700 mb-2">
                Nombre completo <span class="text-[#1d0cdf]">*</span>
              </label>
              <input
                id="cf-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Ej: Andrés Castillo"
                class="input-pro"
              />
            </div>
            <div>
              <label for="cf-company" class="block text-sm font-medium text-slate-700 mb-2">
                Empresa
              </label>
              <input
                id="cf-company"
                name="company"
                type="text"
                autocomplete="organization"
                placeholder="Nombre de tu empresa"
                class="input-pro"
              />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="cf-email" class="block text-sm font-medium text-slate-700 mb-2">
                Correo electrónico <span class="text-[#1d0cdf]">*</span>
              </label>
              <input
                id="cf-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="tu@empresa.com"
                class="input-pro"
              />
            </div>
            <div>
              <label for="cf-whatsapp" class="block text-sm font-medium text-slate-700 mb-2">
                WhatsApp <span class="text-[#1d0cdf]">*</span>
              </label>
              <input
                id="cf-whatsapp"
                name="whatsapp"
                type="tel"
                required
                autocomplete="tel"
                placeholder="+57 300 000 0000"
                class="input-pro"
              />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="cf-service" class="block text-sm font-medium text-slate-700 mb-2">
                Servicio de interés <span class="text-[#1d0cdf]">*</span>
              </label>
              <select id="cf-service" name="service" required class="input-pro">
                <option value="" disabled selected>Selecciona uno…</option>
                <option value="Software a medida">Software a medida</option>
                <option value="Página web">Página web</option>
                <option value="Aplicación web">Aplicación web</option>
                <option value="Automatización">Automatización</option>
                <option value="Bot con IA">Bot con IA</option>
                <option value="Integración API">Integración API</option>
                <option value="Linux & Cloud">Linux & Cloud</option>
                <option value="Consultoría">Consultoría</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div>
              <label for="cf-budget" class="block text-sm font-medium text-slate-700 mb-2">
                Presupuesto estimado
              </label>
              <select id="cf-budget" name="budget" class="input-pro">
                <option value="" selected>Aún no tengo definido</option>
                <option value="Menos de $1.000.000 COP">Menos de $1.000.000 COP</option>
                <option value="$1.000.000 - $3.000.000 COP">$1.000.000 - $3.000.000 COP</option>
                <option value="$3.000.000 - $7.000.000 COP">$3.000.000 - $7.000.000 COP</option>
                <option value="Más de $7.000.000 COP">Más de $7.000.000 COP</option>
              </select>
            </div>
          </div>

          <div>
            <label for="cf-message" class="block text-sm font-medium text-slate-700 mb-2">
              Mensaje <span class="text-[#1d0cdf]">*</span>
            </label>
            <textarea
              id="cf-message"
              name="message"
              rows="5"
              required
              placeholder="Cuéntanos brevemente qué necesitas, plazos y contexto si lo conoces."
              class="input-pro resize-none"></textarea>
          </div>

          <label class="flex items-start gap-3 text-sm text-slate-600">
            <input
              type="checkbox"
              name="consent"
              required
              class="mt-1 h-4 w-4 rounded border-slate-300 text-[#1d0cdf] focus:ring-[#1d0cdf]"
            />
            <span>
              Acepto la
              <a
                href="/privacidad"
                class="text-[#1d0cdf] hover:text-[#1709b8] underline underline-offset-2"
              >
                política de privacidad
              </a>
              y autorizo el contacto comercial.
            </span>
          </label>

          <div class="flex flex-col sm:flex-row gap-3">
            <button type="submit" class="btn-primary flex-1" data-default-text="Enviar solicitud">
              <Icon name="tabler:send" class="h-5 w-5" />
              <span data-btn-label>Enviar solicitud</span>
            </button>
          </div>

          <p class="text-xs text-slate-500 inline-flex items-center gap-1.5">
            <Icon name="tabler:clock-hour-4" class="h-4 w-4 text-[#1d0cdf]" />
            Te responderemos en menos de 24 horas hábiles.
          </p>

          <p
            id="cf-status"
            class="hidden rounded-lg border px-4 py-3 text-sm"
            role="status"
            aria-live="polite"
          >
          </p>
        </form>
      </div>

      <!-- Tarjeta lateral de contacto -->
      <aside class="lg:col-span-4" data-reveal data-reveal-delay="200">
        <div class="rounded-3xl p-6 md:p-8 text-white shadow-card relative overflow-hidden" style="background-color: #1d0cdf;">
          <div
            class="pointer-events-none absolute inset-0 opacity-15"
            style="background-image: linear-gradient(rgb(255 255 255 / 0.14) 1px, transparent 1px), linear-gradient(to right, rgb(255 255 255 / 0.14) 1px, transparent 1px); background-size: 40px 40px;"
            aria-hidden="true"
          ></div>
          <h3 class="relative text-xl md:text-2xl font-bold">Información de contacto</h3>
          <p class="relative mt-2 text-white/80 text-sm">Estamos para ayudarte a dar el siguiente paso digital.</p>

          <ul class="relative mt-6 space-y-5">
            <li class="flex items-start gap-4">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/20">
                <Icon name="tabler:mail" class="h-5 w-5 text-white" />
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/70">Email</p>
                <a href="mailto:contacto@tachetech.com" class="text-base font-semibold text-white hover:underline">
                  contacto@tachetech.com
                </a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/20">
                <Icon name="tabler:brand-whatsapp" class="h-5 w-5 text-white" />
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/70">WhatsApp</p>
                <a href="https://wa.link/3bqb4e" target="_blank" rel="noopener noreferrer" class="text-base font-semibold text-white hover:underline">
                  +57 301 374 5541
                </a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/20">
                <Icon name="tabler:map-pin" class="h-5 w-5 text-white" />
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/70">Oficina Montería</p>
                <p class="text-base font-semibold text-white">Centro de Negocios · Calle 24 # 8 - 46</p>
                <p class="text-sm text-white/80">Montería, Córdoba — Colombia</p>
              </div>
            </li>
          </ul>

          <ul class="relative mt-6 space-y-2.5 text-sm text-white/90">
            <li class="inline-flex items-center gap-2">
              <Icon name="tabler:check" class="h-4 w-4" />
              Respuesta rápida
            </li>
            <li class="inline-flex items-center gap-2">
              <Icon name="tabler:check" class="h-4 w-4" />
              Asesoría inicial sin compromiso
            </li>
            <li class="inline-flex items-center gap-2">
              <Icon name="tabler:check" class="h-4 w-4" />
              Trabajamos remoto con toda Colombia
            </li>
          </ul>

          <a
            href="https://wa.link/3bqb4e"
            target="_blank"
            rel="noopener noreferrer"
            class="relative mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full bg-white px-6 py-3 font-semibold text-[#1d0cdf] transition-all hover:bg-slate-50 hover:-translate-y-0.5"
          >
            <Icon name="tabler:brand-whatsapp" class="h-5 w-5 text-emerald-600" />
            Escribir por WhatsApp
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  type Status = 'success' | 'error' | 'info';

  const showStatus = (form: HTMLFormElement, kind: Status, message: string) => {
    const el = form.querySelector<HTMLParagraphElement>('#cf-status');
    if (!el) return;
    el.textContent = message;
    el.className = 'rounded-lg border px-4 py-3 text-sm';
    if (kind === 'success') {
      el.classList.add('border-emerald-400/40', 'bg-emerald-50', 'text-emerald-800');
    } else if (kind === 'error') {
      el.classList.add('border-red-400/40', 'bg-red-50', 'text-red-800');
    } else {
      el.classList.add('border-[#1d0cdf]/30', 'bg-[#eef0ff]', 'text-[#1d0cdf]');
    }
  };

  const buildWhatsappUrl = (phone: string, data: Record<string, string>) => {
    const lines = [
      `*Nueva solicitud desde tachetech.com*`,
      ``,
      `*Nombre:* ${data.name}`,
      data.company ? `*Empresa:* ${data.company}` : '',
      `*Email:* ${data.email}`,
      `*WhatsApp:* ${data.whatsapp}`,
      `*Servicio:* ${data.service}`,
      data.budget ? `*Presupuesto:* ${data.budget}` : '',
      ``,
      `*Mensaje:*`,
      data.message,
    ].filter(Boolean);
    return `https://wa.me/${phone}?text=${encodeURIComponent(lines.join('\n'))}`;
  };

  const initContactForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = {
        name: String(formData.get('name') || '').trim(),
        company: String(formData.get('company') || '').trim(),
        email: String(formData.get('email') || '').trim(),
        whatsapp: String(formData.get('whatsapp') || '').trim(),
        service: String(formData.get('service') || '').trim(),
        budget: String(formData.get('budget') || '').trim(),
        message: String(formData.get('message') || '').trim(),
      };

      if (!data.name || !data.email || !data.whatsapp || !data.service || !data.message) {
        showStatus(form, 'error', 'Por favor completa los campos obligatorios antes de enviar.');
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) {
        showStatus(form, 'error', 'El correo electrónico no parece válido.');
        return;
      }

      const statusEl = form.querySelector<HTMLParagraphElement>('#cf-status');
      if (statusEl) statusEl.classList.remove('hidden');

      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const label = form.querySelector<HTMLSpanElement>('[data-btn-label]');
      const phone = (form.dataset.whatsapp || '').replace(/\D/g, '');
      const endpoint = form.dataset.endpoint || '';

      if (submitBtn) submitBtn.disabled = true;
      if (label) label.textContent = 'Enviando…';

      if (endpoint) {
        fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        }).catch((err) => console.warn('Backend POST falló:', err));
      }

      const url = buildWhatsappUrl(phone, data);
      window.open(url, '_blank', 'noopener,noreferrer');

      showStatus(
        form,
        'success',
        '¡Solicitud enviada! Abrimos WhatsApp con tu mensaje listo. También te escribiremos por email.'
      );
      if (label) label.textContent = 'Enviar solicitud';
      if (submitBtn) submitBtn.disabled = false;
      form.reset();
    });
  };

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
