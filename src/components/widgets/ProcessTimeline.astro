---
import { Icon } from 'astro-icon/components';

export interface Step {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  items: Step[];
}

const {
  id = 'metodologia',
  eyebrow = 'Metodología',
  title = 'Nuestra Metodología',
  subtitle = 'Un proceso transparente para convertir tu idea en una solución digital confiable.',
  items,
} = Astro.props;
---

<section id={id} class="section">
  <div class="container-pro">
    <div class="mx-auto max-w-3xl text-center mb-14 md:mb-20">
      {eyebrow && (
        <span class="badge-eyebrow" data-reveal>{eyebrow}</span>
      )}
      <h2 class="h2 mt-5 text-slate-900" data-reveal data-reveal-delay="100">
        {title}
      </h2>
      <p class="lead mt-5" data-reveal data-reveal-delay="200">
        {subtitle}
      </p>
    </div>

    <!-- Desktop: horizontal -->
    <div class="hidden lg:block">
      <div class="relative">
        <!-- Línea conectora horizontal -->
        <div
          class="pointer-events-none absolute top-8 left-0 right-0 h-px"
          style="background-image: linear-gradient(to right, rgba(29,12,223,0) 0%, rgba(29,12,223,0.25) 15%, rgba(29,12,223,0.25) 85%, rgba(29,12,223,0) 100%);"
          aria-hidden="true"
        ></div>

        <ol
          class:list={[
            'relative grid gap-6',
            items.length === 5 ? 'grid-cols-5' : items.length === 4 ? 'grid-cols-4' : 'grid-cols-3',
          ]}
        >
          {
            items.map((step, idx) => (
              <li
                class="relative flex flex-col items-center text-center"
                data-reveal
                data-reveal-delay={Math.min((idx + 1) * 100, 500).toString()}
              >
                <div class="relative flex h-16 w-16 items-center justify-center rounded-full bg-white ring-2 ring-[#1d0cdf]/15 shadow-card">
                  <span class="absolute inset-0 rounded-full bg-gradient-brand opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
                  <span class="text-xl font-bold text-[#1d0cdf]">{String(idx + 1).padStart(2, '0')}</span>
                </div>
                <span class="mt-4 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[#eef0ff] text-[#1d0cdf]">
                  <Icon name={step.icon} class="h-5 w-5" />
                </span>
                <h3 class="mt-4 text-lg font-semibold text-slate-900">{step.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600 max-w-[220px]">{step.description}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <!-- Tablet / mobile: vertical -->
    <div class="lg:hidden">
      <div class="relative">
        <div
          class="pointer-events-none absolute left-8 top-0 bottom-0 w-px"
          style="background-image: linear-gradient(to bottom, rgba(29,12,223,0) 0%, rgba(29,12,223,0.25) 10%, rgba(29,12,223,0.25) 90%, rgba(29,12,223,0) 100%);"
          aria-hidden="true"
        ></div>

        <ol class="space-y-6">
          {
            items.map((step, idx) => (
              <li class="relative pl-20" data-reveal data-reveal-delay="100">
                <div class="absolute left-0 top-0 flex h-16 w-16 items-center justify-center rounded-full bg-white ring-2 ring-[#1d0cdf]/15 shadow-card">
                  <span class="text-lg font-bold text-[#1d0cdf]">{String(idx + 1).padStart(2, '0')}</span>
                </div>
                <div class="card">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[#eef0ff] text-[#1d0cdf]">
                      <Icon name={step.icon} class="h-5 w-5" />
                    </span>
                    <h3 class="text-lg font-semibold text-slate-900">{step.title}</h3>
                  </div>
                  <p class="mt-3 text-[15px] leading-relaxed text-slate-600">{step.description}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>
