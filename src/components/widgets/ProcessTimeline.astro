---
import { Icon } from 'astro-icon/components';

export interface Step {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  id?: string;
  tagline?: string;
  title?: string;
  subtitle?: string;
  items: Step[];
}

const {
  id = 'proceso',
  title = 'Un proceso claro, sin sorpresas',
  subtitle = 'Pensado para que estés en control en cada etapa de tu proyecto.',
  items,
} = Astro.props;
---

<section id={id} class="relative py-20 md:py-28 scroll-mt-[72px]">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center mb-16 md:mb-20">
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 dark:text-white"
        data-reveal
      >
        {title}
      </h2>
      <p class="mt-5 text-lg text-slate-600 dark:text-slate-300" data-reveal data-reveal-delay="100">
        {subtitle}
      </p>
    </div>

    <div class="relative">
      <!-- Línea vertical central (desktop) / izquierda (móvil) -->
      <div
        class="pointer-events-none absolute left-7 top-0 bottom-0 w-px bg-gradient-to-b from-blue-500/0 via-blue-500/40 to-cyan-400/0 md:left-1/2 md:-translate-x-1/2"
        aria-hidden="true"
      >
      </div>

      <ol class="space-y-10 md:space-y-16">
        {
          items.map((step, idx) => {
            const isLeft = idx % 2 === 0;
            return (
              <li class="relative md:grid md:grid-cols-2 md:gap-12" data-reveal data-reveal-delay="100">
                {/* Card */}
                <div
                  class:list={[
                    'pl-20 md:pl-0',
                    isLeft ? 'md:col-start-1 md:pr-8 md:text-right' : 'md:col-start-2 md:pl-8',
                  ]}
                >
                  <div class="card-glass">
                    <span class="text-xs font-bold uppercase tracking-[0.2em] text-blue-600 dark:text-cyan-300">
                      Paso {idx + 1}
                    </span>
                    <h3 class="mt-3 text-xl font-semibold text-slate-900 dark:text-white">{step.title}</h3>
                    <p class="mt-2 text-[15px] leading-relaxed text-slate-600 dark:text-slate-300">{step.description}</p>
                  </div>
                </div>

                {/* Nodo central con icono */}
                <div
                  class="absolute left-0 top-2 flex h-14 w-14 items-center justify-center md:left-1/2 md:-translate-x-1/2"
                  aria-hidden="true"
                >
                  <span class="absolute inset-0 rounded-full bg-gradient-brand opacity-30 blur-md" />
                  <span class="relative flex h-14 w-14 items-center justify-center rounded-full border border-slate-200 dark:border-white/15 bg-white dark:bg-[#0F172A] text-blue-600 dark:text-white shadow-lg ring-glow">
                    <Icon name={step.icon} class="h-6 w-6" />
                  </span>
                </div>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
