---
import { Icon } from 'astro-icon/components';
---

<section id="por-que-elegirnos" class="section bg-section">
  <div class="container-pro">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
      <!-- Columna izquierda: copy -->
      <div class="lg:col-span-5" data-reveal>
        <span class="badge-eyebrow">¿Por qué Tache?</span>
        <h2 class="h2 mt-5 text-slate-900">
          La diferencia entre un proveedor y un <span class="text-[#1d0cdf]">socio tecnológico</span>
        </h2>
        <p class="lead mt-5">
          No somos una agencia que entrega y desaparece. Trabajamos contigo durante todo el ciclo de vida
          del producto: desde la primera conversación hasta el soporte y la evolución continua.
        </p>
        <a href="/contacto" class="btn-primary mt-8 inline-flex">
          Hablar con un experto
          <Icon name="tabler:arrow-right" class="w-5 h-5" />
        </a>
      </div>

      <!-- Columna derecha: 4 features -->
      <div class="lg:col-span-7">
        <div class="grid gap-5 sm:grid-cols-2">
          {
            [
              {
                icon: 'tabler:adjustments',
                title: 'Soluciones personalizadas',
                description:
                  'Cero plantillas genéricas. Cada proyecto se diseña pensando en tu modelo de negocio.',
              },
              {
                icon: 'tabler:rocket',
                title: 'Tecnología moderna',
                description:
                  'Trabajamos con herramientas actuales para que tu producto siga vigente con el tiempo.',
              },
              {
                icon: 'tabler:chart-arrows',
                title: 'Enfoque en resultados',
                description:
                  'Medimos lo que importa: ventas, ahorro de horas, ingresos. No solo entregamos código.',
              },
              {
                icon: 'tabler:shield-check',
                title: 'Acompañamiento constante',
                description:
                  'Soporte continuo, mantenimiento y mejoras. Tu producto evoluciona, nosotros también.',
              },
            ].map((item, idx) => (
              <article
                class="card"
                data-reveal
                data-reveal-delay={(((idx % 2) * 100) + 100).toString()}
              >
                <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-[#eef0ff] text-[#1d0cdf] ring-1 ring-[#1d0cdf]/10">
                  <Icon name={item.icon} class="h-5 w-5" />
                </span>
                <h3 class="mt-4 text-lg font-semibold text-slate-900">{item.title}</h3>
                <p class="mt-2 text-[15px] leading-relaxed text-slate-600">{item.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
