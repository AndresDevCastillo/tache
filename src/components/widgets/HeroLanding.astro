---
import { Icon } from 'astro-icon/components';
import { WHATSAPP_URL } from '~/navigation';
---

<section class="relative isolate overflow-hidden" id="inicio" aria-labelledby="hero-heading">
  <!-- Atmósfera sutil -->
  <div class="pointer-events-none absolute inset-0 -z-10 bg-radial-spotlight" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 -z-10 bg-grid opacity-60" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute -top-24 -right-24 -z-10 h-[520px] w-[520px] rounded-full blur-3xl opacity-60"
    style="background: radial-gradient(circle, rgb(29 12 223 / 0.18), transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="container-pro pt-28 md:pt-32 lg:pt-36 pb-16 md:pb-20 lg:pb-28">
    <div class="grid items-center gap-12 lg:gap-16 lg:grid-cols-12">
      <!-- Columna izquierda: copy -->
      <div class="lg:col-span-6">
        <span class="badge-eyebrow" data-reveal>
          <span class="h-1.5 w-1.5 rounded-full bg-[#1d0cdf]"></span>
          Soluciones digitales para empresas
        </span>

        <h1
          id="hero-heading"
          class="h1 mt-6 text-slate-900"
          data-reveal
          data-reveal-delay="100"
        >
          Impulsamos tu empresa con
          <span class="text-[#1d0cdf]">software a medida</span>,
          <span class="text-[#1d0cdf]">páginas web</span>
          y
          <span class="text-[#1d0cdf]">automatización</span>
        </h1>

        <p
          class="lead mt-6 max-w-xl"
          data-reveal
          data-reveal-delay="200"
        >
          Creamos soluciones digitales para ayudarte a captar más clientes, automatizar procesos y
          trabajar mejor con tecnología moderna.
        </p>

        <div
          class="mt-8 flex flex-col sm:flex-row items-stretch sm:items-center gap-3"
          data-reveal
          data-reveal-delay="300"
        >
          <a href="/contacto" class="btn-primary w-full sm:w-auto">
            Agendar asesoría gratis
            <Icon name="tabler:arrow-right" class="h-5 w-5" />
          </a>
          <a href="#servicios" class="btn-secondary w-full sm:w-auto">
            Ver servicios
          </a>
        </div>

        <div
          class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-slate-600"
          data-reveal
          data-reveal-delay="400"
        >
          <div class="inline-flex items-center gap-2">
            <Icon name="tabler:shield-check" class="h-5 w-5 text-[#1d0cdf]" />
            Asesoría sin compromiso
          </div>
          <div class="inline-flex items-center gap-2">
            <Icon name="tabler:clock-hour-4" class="h-5 w-5 text-[#1d0cdf]" />
            Respuesta en 24 horas hábiles
          </div>
          <div class="inline-flex items-center gap-2">
            <Icon name="tabler:map-pin" class="h-5 w-5 text-[#1d0cdf]" />
            Montería · Colombia
          </div>
        </div>
      </div>

      <!-- Columna derecha: Mockup dashboard -->
      <div class="lg:col-span-6 relative" data-reveal data-reveal-delay="200">
        <div class="relative mx-auto max-w-[640px]">
          <!-- Halo detrás -->
          <div
            class="absolute -inset-6 -z-10 rounded-[36px] blur-3xl opacity-60"
            style="background: radial-gradient(60% 55% at 50% 50%, rgb(29 12 223 / 0.22), transparent 70%);"
            aria-hidden="true"
          ></div>

          <!-- Dashboard card -->
          <div class="relative overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-card">
            <!-- Top bar -->
            <div class="flex items-center justify-between border-b border-slate-100 px-5 py-3">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-rose-400/70"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-amber-400/70"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/70"></span>
              </div>
              <div class="hidden sm:flex items-center gap-2 rounded-lg bg-slate-100 px-3 py-1.5 text-xs font-medium text-slate-500">
                <Icon name="tabler:lock" class="h-3.5 w-3.5" />
                panel.tachetech.com
              </div>
              <div class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 ring-1 ring-emerald-200">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse-glow"></span>
                En línea
              </div>
            </div>

            <!-- Dashboard content -->
            <div class="grid grid-cols-12 gap-4 p-5 md:p-6">
              <!-- Sidebar -->
              <div class="col-span-3 space-y-2 hidden md:block">
                <div class="flex items-center gap-2 rounded-lg bg-[#eef0ff] px-3 py-2 text-xs font-semibold text-[#1d0cdf]">
                  <Icon name="tabler:layout-dashboard" class="h-4 w-4" />
                  Panel
                </div>
                <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-xs text-slate-600">
                  <Icon name="tabler:users" class="h-4 w-4" />
                  Clientes
                </div>
                <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-xs text-slate-600">
                  <Icon name="tabler:activity" class="h-4 w-4" />
                  Procesos
                </div>
                <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-xs text-slate-600">
                  <Icon name="tabler:robot" class="h-4 w-4" />
                  Automatización
                </div>
                <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-xs text-slate-600">
                  <Icon name="tabler:chart-dots" class="h-4 w-4" />
                  Reportes
                </div>
              </div>

              <!-- Main -->
              <div class="col-span-12 md:col-span-9 space-y-4">
                <!-- KPIs -->
                <div class="grid grid-cols-3 gap-3">
                  <div class="rounded-xl border border-slate-100 bg-slate-50/80 p-3">
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Ingresos</p>
                    <p class="mt-1 text-lg font-bold text-slate-900">$48.9K</p>
                    <p class="mt-1 inline-flex items-center gap-0.5 text-[11px] font-semibold text-emerald-600">
                      <Icon name="tabler:trending-up" class="h-3 w-3" />
                      +18%
                    </p>
                  </div>
                  <div class="rounded-xl border border-slate-100 bg-slate-50/80 p-3">
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Clientes</p>
                    <p class="mt-1 text-lg font-bold text-slate-900">1,284</p>
                    <p class="mt-1 inline-flex items-center gap-0.5 text-[11px] font-semibold text-emerald-600">
                      <Icon name="tabler:trending-up" class="h-3 w-3" />
                      +9%
                    </p>
                  </div>
                  <div class="rounded-xl border border-slate-100 bg-slate-50/80 p-3">
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Procesos</p>
                    <p class="mt-1 text-lg font-bold text-slate-900">342</p>
                    <p class="mt-1 inline-flex items-center gap-0.5 text-[11px] font-semibold text-[#1d0cdf]">
                      <Icon name="tabler:bolt" class="h-3 w-3" />
                      Automatizados
                    </p>
                  </div>
                </div>

                <!-- Chart -->
                <div class="rounded-xl border border-slate-100 bg-white p-4">
                  <div class="flex items-center justify-between">
                    <p class="text-xs font-semibold text-slate-700">Actividad últimas 2 semanas</p>
                    <span class="text-[10px] font-semibold text-slate-500">Automatizado</span>
                  </div>
                  <div class="mt-3 flex items-end gap-1.5 h-24">
                    {
                      [34, 52, 40, 64, 48, 72, 58, 80, 66, 88, 74, 92, 82, 96].map((h, i) => (
                        <div
                          class:list={[
                            'flex-1 rounded-t-md transition-all',
                            i >= 10 ? 'bg-[#1d0cdf]' : 'bg-slate-200',
                          ]}
                          style={`height: ${h}%;`}
                        />
                      ))
                    }
                  </div>
                </div>

                <!-- Rows -->
                <div class="space-y-2">
                  <div class="flex items-center justify-between rounded-lg border border-slate-100 bg-slate-50/60 px-3 py-2.5">
                    <div class="flex items-center gap-2.5">
                      <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-[#eef0ff] text-[#1d0cdf]">
                        <Icon name="tabler:brand-whatsapp" class="h-4 w-4" />
                      </span>
                      <div>
                        <p class="text-xs font-semibold text-slate-800">Bot WhatsApp</p>
                        <p class="text-[10px] text-slate-500">Flujo de atención activo</p>
                      </div>
                    </div>
                    <span class="text-[10px] font-semibold text-emerald-600">OK</span>
                  </div>
                  <div class="flex items-center justify-between rounded-lg border border-slate-100 bg-slate-50/60 px-3 py-2.5">
                    <div class="flex items-center gap-2.5">
                      <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-[#eef0ff] text-[#1d0cdf]">
                        <Icon name="tabler:api" class="h-4 w-4" />
                      </span>
                      <div>
                        <p class="text-xs font-semibold text-slate-800">Integración API</p>
                        <p class="text-[10px] text-slate-500">Sincronizando clientes</p>
                      </div>
                    </div>
                    <span class="text-[10px] font-semibold text-emerald-600">OK</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Tarjetas flotantes -->
          <div
            class="absolute -left-4 sm:-left-10 top-10 hidden sm:flex items-center gap-3 rounded-xl border border-slate-200 bg-white/95 backdrop-blur px-4 py-3 shadow-card animate-float"
            aria-hidden="true"
          >
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[#eef0ff] text-[#1d0cdf]">
              <Icon name="tabler:user-plus" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-xs text-slate-500 leading-none">Nuevos clientes</p>
              <p class="mt-1 text-sm font-bold text-slate-900">+128 este mes</p>
            </div>
          </div>

          <div
            class="absolute -right-3 sm:-right-8 top-36 hidden sm:flex items-center gap-3 rounded-xl border border-slate-200 bg-white/95 backdrop-blur px-4 py-3 shadow-card animate-float-alt"
            aria-hidden="true"
          >
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600">
              <Icon name="tabler:bolt" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-xs text-slate-500 leading-none">Automatización</p>
              <p class="mt-1 text-sm font-bold text-slate-900">Activa 24/7</p>
            </div>
          </div>

          <div
            class="absolute -left-2 sm:-left-6 -bottom-4 hidden md:flex items-center gap-3 rounded-xl border border-slate-200 bg-white/95 backdrop-blur px-4 py-3 shadow-card animate-float"
            style="animation-delay: 1.2s;"
            aria-hidden="true"
          >
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[#eef0ff] text-[#1d0cdf]">
              <Icon name="tabler:database" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-xs text-slate-500 leading-none">Datos</p>
              <p class="mt-1 text-sm font-bold text-slate-900">Centralizados</p>
            </div>
          </div>

          <div
            class="absolute -right-2 sm:-right-6 -bottom-6 hidden md:flex items-center gap-3 rounded-xl border border-slate-200 bg-white/95 backdrop-blur px-4 py-3 shadow-card animate-float-alt"
            style="animation-delay: 0.6s;"
            aria-hidden="true"
          >
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[#eef0ff] text-[#1d0cdf]">
              <Icon name="tabler:stack-2" class="h-5 w-5" />
            </span>
            <div>
              <p class="text-xs text-slate-500 leading-none">Software</p>
              <p class="mt-1 text-sm font-bold text-slate-900">Escalable</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
