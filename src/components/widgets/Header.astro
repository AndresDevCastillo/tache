---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';

import { getHomePermalink, trimSlash } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface ActionLink extends CallToAction {}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<ActionLink>;
  isSticky?: boolean;
  isFullWidth?: boolean;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isFullWidth = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky },
    'top-0 z-40 flex-none mx-auto w-full bg-white/90 backdrop-blur-md border-b border-slate-200/80 transition-[opacity] ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div
    class:list={[
      'relative py-3 px-4 md:px-6 mx-auto w-full md:flex md:justify-between md:items-center',
      {
        'max-w-7xl': !isFullWidth,
      },
    ]}
  >
    <div class="flex justify-between items-center">
      <a class="flex items-center" href={getHomePermalink()} aria-label="Tache Technology — Inicio">
        <Logo />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>
    <nav
      class="items-center w-full md:w-auto hidden md:flex text-slate-700 overflow-y-auto overflow-x-hidden md:overflow-y-visible md:overflow-x-auto"
      aria-label="Navegación principal"
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-xl md:text-[0.95rem] font-medium"
      >
        {
          links.map(({ text, href, links: subLinks }) => (
            <li class={subLinks?.length ? 'dropdown' : ''}>
              {subLinks?.length ? (
                <>
                  <button class="hover:text-[#1d0cdf] px-4 py-3 flex items-center transition-colors">
                    {text}{' '}
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 hidden md:inline" />
                  </button>
                  <ul class="dropdown-menu md:backdrop-blur-md rounded-xl md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-white md:min-w-[220px] md:shadow-card md:border md:border-slate-200 md:mt-1">
                    {subLinks.map(({ text: text2, href: href2 }) => (
                      <li>
                        <a
                          class:list={[
                            'first:rounded-t-xl last:rounded-b-xl md:hover:bg-slate-50 hover:text-[#1d0cdf] py-2.5 px-5 block whitespace-nowrap transition-colors',
                            { 'aw-link-active': href2 === currentPath },
                          ]}
                          href={href2}
                        >
                          {text2}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  class:list={[
                    'hover:text-[#1d0cdf] px-4 py-3 flex items-center transition-colors',
                    { 'aw-link-active': href === currentPath },
                  ]}
                  href={href}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <div
      class="hidden md:flex items-center gap-2 fixed md:static w-full md:w-auto justify-end left-0 bottom-0 p-3 md:p-0 bg-white md:bg-transparent border-t md:border-0 border-slate-200"
    >
      {
        actions?.length ? (
          <div class="flex items-center gap-2">
            {actions.map((btn) => {
              const variantClass =
                btn.variant === 'primary'
                  ? 'btn-primary'
                  : btn.variant === 'whatsapp'
                  ? 'btn-whatsapp'
                  : 'btn-secondary';
              return (
                <a
                  href={btn.href}
                  class={`${variantClass} !py-2.5 !px-5 text-sm whitespace-nowrap`}
                  {...(btn.target ? { target: btn.target, rel: 'noopener noreferrer' } : {})}
                >
                  {btn.icon && <Icon name={btn.icon} class="w-4 h-4" />}
                  {btn.text}
                </a>
              );
            })}
          </div>
        ) : null
      }
    </div>
  </div>
</header>
