---
import { Icon } from 'astro-icon/components';

export interface Project {
  category: string;
  title: string;
  /** Descripción corta (retrocompat) */
  description?: string;
  /** Bloque problema / solución / resultado para estilo "caso de éxito" */
  problem?: string;
  solution?: string;
  result?: string;
  /** URL opcional del caso de éxito (si no, usa /proyectos) */
  href?: string;
  /** Acento de color */
  accent?: 'indigo' | 'blue' | 'cyan' | 'emerald' | 'amber' | 'rose';
  icon?: string;
  ctaText?: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  items: Project[];
  showCta?: boolean;
  /** 'cases' activa el layout con problema/solución/resultado */
  variant?: 'cases' | 'compact';
}

const {
  id = 'proyectos',
  eyebrow = 'Casos de Éxito',
  title = 'Casos de Éxito',
  subtitle = 'Creamos soluciones digitales pensadas para empresas reales.',
  items,
  showCta = true,
  variant = 'cases',
} = Astro.props;

const accentMap: Record<string, { halo: string; chip: string; iconBg: string }> = {
  indigo: {
    halo: 'rgb(238 240 255)',
    chip: 'bg-[#eef0ff] text-[#1d0cdf] ring-[#1d0cdf]/15',
    iconBg: 'bg-[#eef0ff] text-[#1d0cdf]',
  },
  blue: {
    halo: 'rgb(238 240 255)',
    chip: 'bg-[#eef0ff] text-[#1d0cdf] ring-[#1d0cdf]/15',
    iconBg: 'bg-[#eef0ff] text-[#1d0cdf]',
  },
  cyan: {
    halo: 'rgb(238 240 255)',
    chip: 'bg-[#eef0ff] text-[#1d0cdf] ring-[#1d0cdf]/15',
    iconBg: 'bg-[#eef0ff] text-[#1d0cdf]',
  },
  emerald: {
    halo: 'rgb(238 240 255)',
    chip: 'bg-[#eef0ff] text-[#1d0cdf] ring-[#1d0cdf]/15',
    iconBg: 'bg-[#eef0ff] text-[#1d0cdf]',
  },
  amber: {
    halo: 'rgb(238 240 255)',
    chip: 'bg-[#eef0ff] text-[#1d0cdf] ring-[#1d0cdf]/15',
    iconBg: 'bg-[#eef0ff] text-[#1d0cdf]',
  },
  rose: {
    halo: 'rgb(238 240 255)',
    chip: 'bg-[#eef0ff] text-[#1d0cdf] ring-[#1d0cdf]/15',
    iconBg: 'bg-[#eef0ff] text-[#1d0cdf]',
  },
};
---

<section id={id} class="section bg-soft">
  <div class="container-pro">
    <div class="mx-auto max-w-3xl text-center mb-14 md:mb-20">
      {eyebrow && (
        <span class="badge-eyebrow" data-reveal>{eyebrow}</span>
      )}
      <h2 class="h2 mt-5 text-slate-900" data-reveal data-reveal-delay="100">
        {title}
      </h2>
      <p class="lead mt-5" data-reveal data-reveal-delay="200">
        {subtitle}
      </p>
    </div>

    <div class="grid gap-6 md:gap-7 md:grid-cols-2 lg:grid-cols-3">
      {
        items.map((project, idx) => {
          const accent = accentMap[project.accent || 'blue'];
          return (
            <article
              class="card group flex flex-col h-full overflow-hidden p-0"
              data-reveal
              data-reveal-delay={Math.min(((idx % 3) + 1) * 100, 300).toString()}
            >
              {/* Header con halo */}
              <div class="relative h-36 overflow-hidden border-b border-slate-100">
                <div class="absolute inset-0" style={`background-color: ${accent.halo};`} />
                <div class="absolute inset-0 bg-grid opacity-50" />
                <div class="relative flex h-full items-center justify-between px-6">
                  <span
                    class:list={[
                      'inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1',
                      accent.chip,
                    ]}
                  >
                    {project.category}
                  </span>
                  {project.icon && (
                    <span
                      class:list={[
                        'inline-flex h-11 w-11 items-center justify-center rounded-xl transition-transform duration-300 group-hover:scale-110',
                        accent.iconBg,
                      ]}
                    >
                      <Icon name={project.icon} class="h-6 w-6" />
                    </span>
                  )}
                </div>
              </div>

              <div class="flex flex-col flex-grow p-6">
                <h3 class="text-xl font-semibold text-slate-900">{project.title}</h3>

                {variant === 'cases' && (project.problem || project.solution || project.result) ? (
                  <dl class="mt-4 space-y-3 text-sm">
                    {project.problem && (
                      <div>
                        <dt class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Problema</dt>
                        <dd class="mt-0.5 text-[14px] leading-relaxed text-slate-700">{project.problem}</dd>
                      </div>
                    )}
                    {project.solution && (
                      <div>
                        <dt class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Solución</dt>
                        <dd class="mt-0.5 text-[14px] leading-relaxed text-slate-700">{project.solution}</dd>
                      </div>
                    )}
                    {project.result && (
                      <div class="rounded-lg bg-emerald-50/70 border border-emerald-100 px-3 py-2">
                        <dt class="text-[11px] font-semibold uppercase tracking-wider text-emerald-700">Resultado</dt>
                        <dd class="mt-0.5 text-[14px] leading-relaxed text-emerald-900">{project.result}</dd>
                      </div>
                    )}
                  </dl>
                ) : (
                  project.description && (
                    <p class="mt-3 text-[15px] leading-relaxed text-slate-600">{project.description}</p>
                  )
                )}

                <div class="mt-auto pt-6">
                  <a
                    href={project.href || '/proyectos'}
                    class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#1d0cdf] hover:text-[#1709b8]"
                    {...(project.href && project.href.startsWith('http')
                      ? { target: '_blank', rel: 'noopener noreferrer' }
                      : {})}
                  >
                    {project.ctaText || 'Ver caso de éxito'}
                    <Icon
                      name="tabler:arrow-right"
                      class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
                    />
                  </a>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    {
      showCta && (
        <div class="mt-14 md:mt-20 text-center" data-reveal>
          <p class="text-lg text-slate-600">¿Tienes en mente un proyecto similar?</p>
          <a href="/contacto" class="btn-primary mt-5 inline-flex">
            Cuéntanos tu idea
            <Icon name="tabler:arrow-right" class="h-5 w-5" />
          </a>
        </div>
      )
    }
  </div>
</section>
