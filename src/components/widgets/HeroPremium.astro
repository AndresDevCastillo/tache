---
import { Icon } from 'astro-icon/components';

export interface Props {
  /** Override del título principal (HTML permitido). Si vacío, usa el default. */
  title?: string;
  subtitle?: string;
  showCtas?: boolean;
}

const {
  title = '',
  subtitle = 'Desarrollamos software a medida, automatizamos procesos y llevamos tu empresa al siguiente nivel digital — con la cercanía y compromiso de un equipo local.',
  showCtas = true,
} = Astro.props;
---

<section class="relative isolate overflow-hidden md:-mt-[76px]" id="inicio">
  <!-- Blobs de color: solo se ven en dark, sutiles -->
  <div
    class="pointer-events-none absolute -top-32 -left-24 -z-10 h-[420px] w-[420px] rounded-full blur-3xl opacity-50 dark:opacity-100 animate-pulse-glow"
    style="background: radial-gradient(circle, rgb(29 12 223 / 0.45), transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -top-10 right-0 -z-10 h-[380px] w-[380px] rounded-full blur-3xl opacity-50 dark:opacity-100 animate-pulse-glow"
    style="background: radial-gradient(circle, rgb(37 99 235 / 0.40), transparent 70%); animation-delay: 1.5s;"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 pt-32 md:pt-40 pb-20 md:pb-28">
    <div class="mx-auto max-w-4xl text-center">
      {
        title ? (
          <h1
            class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] text-slate-900 dark:text-white"
            data-reveal
            set:html={title}
          />
        ) : (
          <h1
            class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] text-slate-900 dark:text-white"
            data-reveal
          >
            Transformamos ideas en
            <span class="text-gradient animate-gradient">soluciones tecnológicas</span>
            que impulsan tu negocio
          </h1>
        )
      }

      <p
        class="mt-6 md:mt-8 text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto leading-relaxed"
        data-reveal
        data-reveal-delay="100"
      >
        {subtitle}
      </p>

      {
        showCtas && (
          <div
            class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4"
            data-reveal
            data-reveal-delay="200"
          >
            <a href="/contacto" class="btn-primary w-full sm:w-auto">
              Solicitar asesoría
              <Icon name="tabler:arrow-right" class="w-5 h-5" />
            </a>
            <a href="/contacto#contacto" class="btn-secondary w-full sm:w-auto">
              <Icon name="tabler:calculator" class="w-5 h-5" />
              Cotizar proyecto
            </a>
            <a
              href="https://wa.link/3bqb4e"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp w-full sm:w-auto"
            >
              <Icon name="tabler:brand-whatsapp" class="w-5 h-5" />
              WhatsApp
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>
