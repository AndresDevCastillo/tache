---
import { Icon } from 'astro-icon/components';

export interface Props {
  title?: string;
  subtitle?: string;
  showCtas?: boolean;
  eyebrow?: string;
}

const {
  title = '',
  subtitle = 'Soluciones digitales para empresas — software a medida, páginas web, automatización y mucho más.',
  showCtas = true,
  eyebrow = '',
} = Astro.props;
---

<section class="relative isolate overflow-hidden" id="inicio">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-radial-spotlight" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 -z-10 bg-grid opacity-50" aria-hidden="true"></div>

  <div class="relative container-pro pt-28 md:pt-32 pb-16 md:pb-20">
    <div class="mx-auto max-w-4xl text-center">
      {eyebrow && (
        <span class="badge-eyebrow mb-6 inline-flex" data-reveal>
          {eyebrow}
        </span>
      )}
      {
        title ? (
          <h1
            class="h1 text-slate-900"
            data-reveal
            set:html={title}
          />
        ) : (
          <h1
            class="h1 text-slate-900"
            data-reveal
          >
            Transformamos ideas en
            <span class="text-gradient animate-gradient">soluciones tecnológicas</span>
            que impulsan tu negocio
          </h1>
        )
      }

      <p
        class="lead mt-6 max-w-2xl mx-auto"
        data-reveal
        data-reveal-delay="100"
      >
        {subtitle}
      </p>

      {
        showCtas && (
          <div
            class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3"
            data-reveal
            data-reveal-delay="200"
          >
            <a href="/contacto" class="btn-primary w-full sm:w-auto">
              Solicitar asesoría gratis
              <Icon name="tabler:arrow-right" class="w-5 h-5" />
            </a>
            <a href="https://wa.link/3bqb4e" target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full sm:w-auto">
              <Icon name="tabler:brand-whatsapp" class="w-5 h-5" />
              WhatsApp
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>
