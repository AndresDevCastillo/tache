---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import Logo from '~/components/Logo.astro';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface LinkGroup {
  title?: string;
  links: Array<Link>;
}

interface Contact {
  title?: string;
  email?: string;
  phone?: string;
  phoneHref?: string;
  whatsapp?: string;
  location?: string;
}

interface Brand {
  description?: string;
}

export interface Props {
  brand?: Brand;
  links?: Array<LinkGroup>;
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  contact?: Contact;
  copyright?: string;
  madeIn?: string;
  /** Compat — antes se pasaba como HTML */
  footNote?: string;
}

const {
  brand = {},
  links = [],
  secondaryLinks = [],
  socialLinks = [],
  contact,
  copyright = `© ${new Date().getFullYear()} Tache Technology. Todos los derechos reservados.`,
  madeIn = 'Hecho con tecnología desde Montería, Colombia.',
} = Astro.props;
---

<footer class="relative border-t border-slate-200 bg-white">
  <div class="container-pro py-14 md:py-16">
    <div class="grid gap-10 md:gap-12 lg:grid-cols-12">
      <!-- Marca + descripción + social -->
      <div class="lg:col-span-4">
        <a class="inline-flex items-center" href={getHomePermalink()} aria-label="Tache Technology — Inicio">
          <Logo />
        </a>
        {brand.description && (
          <p class="mt-4 text-sm leading-relaxed text-slate-600 max-w-sm">{brand.description}</p>
        )}

        {socialLinks?.length > 0 && (
          <ul class="mt-6 flex items-center gap-2">
            {socialLinks.map(({ ariaLabel, href, icon }) => (
              <li>
                <a
                  class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 transition-all hover:border-[#1d0cdf]/30 hover:text-[#1d0cdf] hover:bg-[#eef0ff]"
                  aria-label={ariaLabel}
                  href={href}
                  {...(href && href.startsWith('http')
                    ? { target: '_blank', rel: 'noopener noreferrer' }
                    : {})}
                >
                  {icon && <Icon name={icon} class="h-5 w-5" />}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <!-- Grupos de enlaces -->
      <div class="lg:col-span-5 grid grid-cols-2 sm:grid-cols-3 gap-6 md:gap-8">
        {
          links.map(({ title, links: groupLinks }) => (
            <div>
              <p class="text-sm font-semibold text-slate-900">{title}</p>
              {groupLinks && groupLinks.length > 0 && (
                <ul class="mt-3 space-y-2">
                  {groupLinks.map(({ text, href, ariaLabel }) => (
                    <li>
                      <a
                        class="text-sm text-slate-600 hover:text-[#1d0cdf] transition-colors"
                        href={href}
                        aria-label={ariaLabel}
                      >
                        {text}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))
        }
      </div>

      <!-- Contacto -->
      {contact && (
        <div class="lg:col-span-3">
          <p class="text-sm font-semibold text-slate-900">{contact.title || 'Contacto'}</p>
          <ul class="mt-3 space-y-3 text-sm">
            {contact.email && (
              <li class="flex items-start gap-2.5">
                <Icon name="tabler:mail" class="h-4 w-4 text-[#1d0cdf] mt-0.5 flex-shrink-0" />
                <a href={`mailto:${contact.email}`} class="text-slate-600 hover:text-[#1d0cdf] transition-colors break-all">
                  {contact.email}
                </a>
              </li>
            )}
            {contact.phone && (
              <li class="flex items-start gap-2.5">
                <Icon name="tabler:phone" class="h-4 w-4 text-[#1d0cdf] mt-0.5 flex-shrink-0" />
                <a
                  href={contact.phoneHref || `tel:${contact.phone.replace(/\s+/g, '')}`}
                  class="text-slate-600 hover:text-[#1d0cdf] transition-colors"
                >
                  {contact.phone}
                </a>
              </li>
            )}
            {contact.whatsapp && (
              <li class="flex items-start gap-2.5">
                <Icon name="tabler:brand-whatsapp" class="h-4 w-4 text-emerald-600 mt-0.5 flex-shrink-0" />
                <a
                  href={contact.whatsapp}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-slate-600 hover:text-[#1d0cdf] transition-colors"
                >
                  Escríbenos por WhatsApp
                </a>
              </li>
            )}
            {contact.location && (
              <li class="flex items-start gap-2.5">
                <Icon name="tabler:map-pin" class="h-4 w-4 text-[#1d0cdf] mt-0.5 flex-shrink-0" />
                <span class="text-slate-600">{contact.location}</span>
              </li>
            )}
          </ul>
        </div>
      )}
    </div>

    <!-- Barra inferior -->
    <div class="mt-10 md:mt-14 pt-6 border-t border-slate-200 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-sm text-slate-500">{copyright}</p>

      {secondaryLinks?.length > 0 && (
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
          {secondaryLinks.map(({ text, href }) => (
            <li>
              <a href={href} class="text-slate-500 hover:text-[#1d0cdf] transition-colors">
                {text}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>

    {madeIn && (
      <p class="mt-3 text-xs text-slate-400 inline-flex items-center gap-1.5">
        <Icon name="tabler:map-pin" class="h-3.5 w-3.5" />
        {madeIn}
      </p>
    )}
  </div>
</footer>
