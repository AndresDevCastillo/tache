---
import Layout from '~/layouts/PageLayout.astro';
import HeroLanding from '~/components/widgets/HeroLanding.astro';
import Challenges from '~/components/widgets/Challenges.astro';
import ServicesGrid from '~/components/widgets/ServicesGrid.astro';
import ProcessTimeline from '~/components/widgets/ProcessTimeline.astro';
import ProjectsGrid from '~/components/widgets/ProjectsGrid.astro';
import SeoLocal from '~/components/widgets/SeoLocal.astro';
import TechStack from '~/components/widgets/TechStack.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import ContactFormPro from '~/components/widgets/ContactFormPro.astro';

const metadata = {
  title: 'Tache Technology | Software a medida, páginas web y automatización en Montería',
  ignoreTitleTemplate: true,
  description:
    'Creamos software a medida, páginas web profesionales y automatización para empresas en Montería, Córdoba y Colombia. Agenda una asesoría gratis.',
};

// 8 servicios del brief
const services = [
  {
    icon: 'tabler:code',
    title: 'Software a medida',
    description:
      'Sistemas personalizados para gestionar procesos, clientes, reportes, inventarios y operaciones.',
  },
  {
    icon: 'tabler:world',
    title: 'Páginas web profesionales',
    description:
      'Sitios modernos, rápidos y optimizados para captar clientes y fortalecer tu presencia digital.',
  },
  {
    icon: 'tabler:devices',
    title: 'Aplicaciones web',
    description:
      'Plataformas seguras y escalables para gestionar tu negocio desde cualquier lugar.',
  },
  {
    icon: 'tabler:bolt',
    title: 'Automatización',
    description:
      'Automatizamos tareas repetitivas conectando formularios, WhatsApp, correos, bases de datos y herramientas.',
  },
  {
    icon: 'tabler:robot',
    title: 'Bots con IA',
    description:
      'Asistentes inteligentes para atención al cliente, agendamiento, preguntas frecuentes y procesos comerciales.',
  },
  {
    icon: 'tabler:api',
    title: 'Integraciones API',
    description:
      'Conectamos sistemas, pagos, CRM, ERP, formularios, bases de datos y plataformas externas.',
  },
  {
    icon: 'tabler:cloud-computing',
    title: 'Linux & Cloud',
    description:
      'Configuramos servidores, dominios, SSL, despliegues, backups, bases de datos y aplicaciones en la nube.',
  },
  {
    icon: 'tabler:compass',
    title: 'Consultoría',
    description:
      'Te ayudamos a definir la mejor solución digital según tus objetivos, presupuesto y etapa del negocio.',
  },
];

// 5 pasos metodología
const methodology = [
  {
    icon: 'tabler:search',
    title: 'Descubrimiento',
    description: 'Entendemos tu negocio, necesidades y objetivos.',
  },
  {
    icon: 'tabler:layout-board',
    title: 'Diseño y plan',
    description: 'Definimos alcance, propuesta, tiempos y tecnologías.',
  },
  {
    icon: 'tabler:code-dots',
    title: 'Desarrollo ágil',
    description: 'Construimos la solución con avances claros y validaciones.',
  },
  {
    icon: 'tabler:rocket',
    title: 'Lanzamiento',
    description: 'Implementamos, probamos y dejamos todo funcionando.',
  },
  {
    icon: 'tabler:lifebuoy',
    title: 'Soporte y mejora',
    description: 'Te acompañamos después de la entrega para optimizar y escalar la solución.',
  },
];

// 3 casos de éxito
const successCases = [
  {
    category: 'Logística',
    title: 'Optimización de entregas',
    problem: 'La empresa tenía procesos manuales y poco seguimiento de entregas.',
    solution: 'Creamos una plataforma web para organizar rutas, estados y control operativo.',
    result: 'Mayor control interno, mejor seguimiento y reducción de tareas manuales.',
    icon: 'tabler:truck-delivery',
    accent: 'blue' as const,
    href: '/proyectos',
  },
  {
    category: 'Inventario',
    title: 'Digitalización de inventario',
    problem: 'El inventario se manejaba con hojas de cálculo y registros manuales.',
    solution: 'Desarrollamos un sistema web para registrar productos, movimientos y reportes.',
    result: 'Información más organizada, mejor trazabilidad y menos errores operativos.',
    icon: 'tabler:box-seam',
    accent: 'indigo' as const,
    href: '/proyectos',
  },
  {
    category: 'Salud',
    title: 'Telemedicina y citas',
    problem: 'La gestión de citas y pacientes se realizaba de forma manual.',
    solution: 'Creamos una plataforma para agendamiento, pacientes y consultas.',
    result: 'Mejor atención, mayor organización y disponibilidad para los usuarios.',
    icon: 'tabler:stethoscope',
    accent: 'cyan' as const,
    href: '/proyectos',
  },
];

// FAQs — usamos el esquema {question, answer} y también lo transformamos a JSON-LD
const faqs = [
  {
    question: '¿Cuánto cuesta desarrollar una página web?',
    answer:
      'Depende del tipo de sitio, funcionalidades y nivel de personalización. Podemos orientarte con una asesoría inicial según las necesidades de tu negocio.',
  },
  {
    question: '¿Cuánto tiempo tarda un proyecto de software?',
    answer:
      'Depende del alcance. Una página web puede tomar pocas semanas, mientras que un sistema a medida puede requerir más tiempo de análisis, desarrollo y pruebas.',
  },
  {
    question: '¿Trabajan con empresas fuera de Montería?',
    answer:
      'Sí. Trabajamos con empresas de Montería, Córdoba, Colombia y otros lugares mediante reuniones virtuales y acompañamiento remoto.',
  },
  {
    question: '¿Pueden automatizar procesos con WhatsApp?',
    answer:
      'Sí. Podemos crear flujos para recibir solicitudes, responder preguntas frecuentes, organizar prospectos y conectar WhatsApp con formularios o sistemas internos.',
  },
  {
    question: '¿Desarrollan software a medida?',
    answer:
      'Sí. Creamos sistemas personalizados según los procesos, necesidades y objetivos de cada empresa.',
  },
  {
    question: '¿Ofrecen soporte después del lanzamiento?',
    answer:
      'Sí. Podemos acompañarte con mantenimiento, mejoras, soporte técnico y evolución del proyecto.',
  },
  {
    question: '¿Qué necesito para empezar mi proyecto?',
    answer:
      'Solo necesitas contarnos tu idea, problema o necesidad. Nosotros te ayudamos a definir la mejor solución, alcance y próximos pasos.',
  },
];

// JSON-LD schemas específicos de la home
const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.answer,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: services.map((s, i) => ({
      '@type': 'Service',
      position: i + 1,
      name: s.title,
      description: s.description,
      provider: { '@id': 'https://tachetech.com/#organization' },
      areaServed: { '@type': 'Country', name: 'Colombia' },
    })),
  },
];
---

<Layout metadata={metadata} schemas={schemas}>
  <!-- 1. Hero principal -->
  <HeroLanding />

  <!-- 2. Retos / problemas del cliente -->
  <Challenges />

  <!-- 3. Servicios -->
  <ServicesGrid
    id="servicios"
    eyebrow="Servicios"
    title="Servicios que transforman"
    subtitle="Soluciones tecnológicas diseñadas para mejorar la operación, presencia digital y crecimiento de tu empresa."
    items={services}
    cardCta="Conocer más"
    fourCols={true}
    allLink={{ text: 'Ver todos los servicios', href: '/servicios' }}
  />

  <!-- 4. Metodología -->
  <ProcessTimeline
    items={methodology}
    eyebrow="Metodología"
    title="Nuestra Metodología"
    subtitle="Un proceso transparente para convertir tu idea en una solución digital confiable."
  />

  <!-- 5. Casos de éxito -->
  <ProjectsGrid
    id="casos"
    eyebrow="Casos de Éxito"
    title="Casos de Éxito"
    subtitle="Creamos soluciones digitales pensadas para empresas reales."
    items={successCases}
    variant="cases"
    showCta={false}
  />

  <!-- 6. SEO local Montería -->
  <SeoLocal />

  <!-- 7. Stack tecnológico -->
  <TechStack />

  <!-- 8. CTA principal -->
  <CtaBanner />

  <!-- 9. Preguntas frecuentes -->
  <FAQs
    id="faqs"
    eyebrow="Preguntas frecuentes"
    title="Preguntas frecuentes"
    items={faqs}
  />

  <!-- 10. Contacto -->
  <ContactFormPro />
</Layout>
