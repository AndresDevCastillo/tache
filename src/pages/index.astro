---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import ServicesGrid from '~/components/widgets/ServicesGrid.astro';
import ProjectsGrid from '~/components/widgets/ProjectsGrid.astro';
import ProcessTimeline from '~/components/widgets/ProcessTimeline.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'TacheTechnology — Software a medida que impulsa tu negocio',
  ignoreTitleTemplate: true,
  description:
    'Diseñamos y construimos páginas web, aplicaciones y soluciones digitales a la medida de tu negocio. Trabajamos cerca de ti, con resultados claros.',
};

// Servicios — copys orientados al beneficio, sin tecnicismos.
const services = [
  {
    icon: 'tabler:world',
    title: 'Páginas web profesionales',
    description:
      'Sitios web modernos, rápidos y que se ven perfectos en cualquier dispositivo. Pensados para que tus clientes te encuentren y confíen en ti.',
  },
  {
    icon: 'tabler:layout-grid',
    title: 'Aplicaciones a la medida',
    description:
      'Creamos plataformas hechas a tu medida para gestionar tu negocio, tus clientes o tu equipo desde un solo lugar — sin complicaciones.',
  },
  {
    icon: 'tabler:sparkles',
    title: 'Automatización inteligente',
    description:
      'Asistentes y procesos automáticos que se encargan de tareas repetitivas, para que tu equipo se enfoque en lo que realmente importa.',
  },
  {
    icon: 'tabler:link',
    title: 'Integraciones entre sistemas',
    description:
      'Conectamos las herramientas que ya usas (pagos, facturación, WhatsApp, etc.) para que trabajen juntas y dejes de copiar datos a mano.',
  },
  {
    icon: 'tabler:cloud',
    title: 'Tu sistema siempre disponible',
    description:
      'Hacemos que tu plataforma esté siempre en línea, segura y rápida. Tú te enfocas en tu negocio, nosotros nos encargamos del lado técnico.',
  },
  {
    icon: 'tabler:headset',
    title: 'Soporte continuo',
    description:
      'Te acompañamos después del lanzamiento con mantenimiento, mejoras y nuevas funciones. No desaparecemos cuando entregamos.',
  },
];

// Vista corta del proceso para la home (la versión completa vive en /proceso).
const processSteps = [
  {
    icon: 'tabler:message-circle',
    title: 'Conversamos',
    description:
      'Empezamos con una charla sin costo donde entendemos tu negocio y qué problema quieres resolver.',
  },
  {
    icon: 'tabler:layout-board',
    title: 'Diseñamos',
    description:
      'Te mostramos cómo se va a ver y funcionar antes de construirlo, y hacemos los ajustes contigo.',
  },
  {
    icon: 'tabler:hammer',
    title: 'Construimos',
    description:
      'Desarrollamos tu proyecto con avances semanales que puedes ver y probar — sin esperas largas.',
  },
  {
    icon: 'tabler:rocket',
    title: 'Lanzamos y acompañamos',
    description:
      'Ponemos tu proyecto en marcha, te capacitamos y seguimos contigo para mejoras y soporte.',
  },
];

// Proyectos destacados (3 para la home; los demás en /proyectos).
const featuredProjects = [
  {
    category: 'Comercio',
    title: 'Tienda online para distribuidora',
    description:
      'Catálogo, carrito y pagos en línea. Antes solo vendían por WhatsApp.',
    result: 'Triplicaron sus pedidos en 3 meses.',
    accent: 'indigo' as const,
    icon: 'tabler:building-store',
  },
  {
    category: 'Salud',
    title: 'Plataforma de citas',
    description:
      'Pacientes que agendan online y recordatorios automáticos para reducir inasistencias.',
    result: 'Inasistencias bajaron 60%.',
    accent: 'cyan' as const,
    icon: 'tabler:dental',
  },
  {
    category: 'Servicios',
    title: 'Asistente virtual 24/7',
    description:
      'Bot inteligente que responde a clientes en la web y WhatsApp todo el día.',
    result: 'Resuelve el 70% de las consultas.',
    accent: 'amber' as const,
    icon: 'tabler:message-chatbot',
  },
];
---

<Layout metadata={metadata}>
  <HeroPremium />

  <!-- Quiénes somos: vista corta + link a página completa -->
  <section id="nosotros-preview" class="relative py-20 md:py-28 scroll-mt-[72px]">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 text-center">
      <span class="pill" data-reveal>
        <span class="dot"></span>
        Quiénes somos
      </span>
      <h2
        class="mt-5 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white"
        data-reveal
        data-reveal-delay="100"
      >
        Tu <span class="text-gradient">socio tecnológico</span>, no solo un proveedor
      </h2>
      <p
        class="mt-6 text-lg text-slate-300 max-w-3xl mx-auto leading-relaxed"
        data-reveal
        data-reveal-delay="200"
      >
        Somos un equipo cercano y comprometido con cada proyecto. Hablamos tu idioma, te acompañamos
        en cada paso y nos importa tanto como a ti que tu negocio crezca.
      </p>
      <a href="/nosotros" class="btn-secondary mt-8 inline-flex" data-reveal data-reveal-delay="300">
        Conoce más sobre nosotros
        <Icon name="tabler:arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </section>

  <!-- Servicios -->
  <ServicesGrid
    items={services}
    cardCta=""
  />
  <div class="text-center -mt-8 mb-16" data-reveal>
    <a href="/servicios" class="btn-secondary inline-flex">
      Ver todos los servicios
      <Icon name="tabler:arrow-right" class="h-4 w-4" />
    </a>
  </div>

  <!-- Proyectos destacados -->
  <ProjectsGrid
    items={featuredProjects}
    title="Algunos proyectos que hemos entregado"
    subtitle="Negocios reales con resultados reales. Te mostramos lo que hemos construido."
    showCta={false}
  />
  <div class="text-center -mt-8 mb-16" data-reveal>
    <a href="/proyectos" class="btn-secondary inline-flex">
      Ver más proyectos
      <Icon name="tabler:arrow-right" class="h-4 w-4" />
    </a>
  </div>

  <!-- Proceso resumido -->
  <ProcessTimeline
    items={processSteps}
    title="Cuatro pasos para llevar tu idea a la realidad"
    subtitle="Un proceso claro y transparente, donde estás en control en todo momento."
  />
  <div class="text-center -mt-12 mb-16" data-reveal>
    <a href="/proceso" class="btn-secondary inline-flex">
      Ver el proceso completo
      <Icon name="tabler:arrow-right" class="h-4 w-4" />
    </a>
  </div>

  <CtaBanner />
</Layout>
