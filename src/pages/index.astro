---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import MissionVision from '~/components/widgets/MissionVision.astro';
import ServicesGrid from '~/components/widgets/ServicesGrid.astro';
import WhyChoose from '~/components/widgets/WhyChoose.astro';
import ProcessTimeline from '~/components/widgets/ProcessTimeline.astro';
import ContactFormPro from '~/components/widgets/ContactFormPro.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'TacheTechnology — Software a medida, IA y automatización',
  ignoreTitleTemplate: true,
  description:
    'Desarrollamos software a medida, automatizamos procesos con IA y llevamos tu empresa al siguiente nivel digital. Startup tecnológica en Montería, Colombia.',
};

const services = [
  {
    icon: 'tabler:device-desktop-code',
    title: 'Desarrollo de páginas web',
    description:
      'Sitios corporativos y landings de alto rendimiento, optimizados para SEO y velocidad. Diseño moderno y conversión-first.',
    benefit: 'Más visibilidad y leads desde el primer mes.',
    gradient: 'bg-gradient-to-br from-indigo-500 to-violet-600',
  },
  {
    icon: 'tabler:apps',
    title: 'Aplicaciones web personalizadas',
    description:
      'Plataformas SaaS, dashboards, CRMs y portales internos construidos sobre stacks modernos (Next.js, NestJS, PostgreSQL).',
    benefit: 'Procesos digitalizados que escalan con tu equipo.',
    gradient: 'bg-gradient-to-br from-violet-500 to-fuchsia-600',
  },
  {
    icon: 'tabler:robot',
    title: 'Automatización con IA',
    description:
      'Chatbots, análisis de datos, generación de contenido y agentes que ejecutan tareas repetitivas usando modelos LLM.',
    benefit: 'Hasta 70% menos tiempo en tareas operativas.',
    gradient: 'bg-gradient-to-br from-cyan-500 to-blue-600',
  },
  {
    icon: 'tabler:plug-connected',
    title: 'Integraciones y APIs',
    description:
      'Conectamos tus herramientas: ERPs, CRMs, pasarelas de pago, WhatsApp Business, facturación electrónica y más.',
    benefit: 'Tu stack hablando entre sí, sin trabajo manual.',
    gradient: 'bg-gradient-to-br from-blue-500 to-indigo-600',
  },
  {
    icon: 'tabler:cloud-cog',
    title: 'Cloud y DevOps',
    description:
      'Despliegues automatizados en AWS, GCP o VPS propios. Infraestructura segura, monitoreada y lista para escalar.',
    benefit: 'Uptime profesional y costos cloud bajo control.',
    gradient: 'bg-gradient-to-br from-emerald-500 to-cyan-600',
  },
  {
    icon: 'tabler:tools',
    title: 'Soporte y evolución continua',
    description:
      'Mantenimiento, nuevas funcionalidades y mejoras de performance. Tu producto digital nunca se queda atrás.',
    benefit: 'Un equipo técnico disponible cuando lo necesites.',
    gradient: 'bg-gradient-to-br from-fuchsia-500 to-pink-600',
  },
];

const processSteps = [
  {
    icon: 'tabler:search',
    title: 'Análisis',
    duration: 'Semana 1',
    description:
      'Entendemos a fondo tu negocio, tus usuarios y los objetivos del proyecto. Definimos alcance, prioridades y métricas de éxito.',
  },
  {
    icon: 'tabler:layout-board',
    title: 'Diseño',
    duration: 'Semanas 2–3',
    description:
      'Wireframes, prototipos navegables y diseño visual con la identidad de tu marca. Iteramos contigo hasta que esté perfecto.',
  },
  {
    icon: 'tabler:code',
    title: 'Desarrollo',
    duration: 'Semanas 4–8',
    description:
      'Código limpio, modular y testeado. Sprints semanales con demos en vivo para que veas el avance real.',
  },
  {
    icon: 'tabler:rocket',
    title: 'Implementación',
    duration: 'Semana 9',
    description:
      'Despliegue a producción con dominio propio, certificados SSL y monitoreo. Capacitación a tu equipo.',
  },
  {
    icon: 'tabler:lifebuoy',
    title: 'Soporte',
    duration: 'Continuo',
    description:
      'Mantenimiento, mejoras, nuevas funcionalidades y respuesta rápida ante cualquier incidencia. Estamos aquí cuando nos necesites.',
  },
];
---

<Layout metadata={metadata}>
  <HeroPremium />

  <MissionVision />

  <ServicesGrid items={services} />

  <WhyChoose />

  <ProcessTimeline items={processSteps} />

  <ContactFormPro whatsappNumber="573013745541" />

  <FAQs
    id="faqs"
    title="Preguntas frecuentes"
    subtitle="Las dudas más comunes antes de empezar un proyecto con nosotros."
    tagline="FAQs"
    classes={{ container: 'max-w-4xl' }}
    items={[
      {
        title: '¿Cuánto tiempo toma desarrollar mi proyecto?',
        description:
          'Una landing o página web simple toma 4 a 6 semanas. Una aplicación web completa entre 2 y 4 meses. Te damos un cronograma detallado tras la fase de análisis.',
      },
      {
        title: '¿Cuánto cuesta?',
        description:
          'Depende del alcance, integraciones y complejidad. Tras una primera reunión de 30 minutos sin compromiso te enviamos una cotización clara, con opciones por fases si tu presupuesto lo requiere.',
      },
      {
        title: '¿Qué necesito tener listo para empezar?',
        description:
          'Idealmente: objetivos del negocio, usuarios objetivo, contenidos (textos, imágenes, logos) y referencias visuales. Si no los tienes, te ayudamos a estructurarlos en la fase de análisis.',
      },
      {
        title: '¿La página/aplicación se ve bien en móvil?',
        description:
          'Siempre. Diseñamos mobile-first y probamos en múltiples dispositivos antes de entregar. Más del 60% del tráfico hoy es móvil — no es opcional.',
      },
      {
        title: '¿Cómo manejan el mantenimiento?',
        description:
          'Ofrecemos planes mensuales con horas de soporte incluidas, monitoreo, actualizaciones de seguridad y mejoras pequeñas. También trabajamos por bolsas de horas o por proyectos puntuales.',
      },
      {
        title: '¿Puedo editar el contenido yo mismo después?',
        description:
          'Sí. Cuando aplica, integramos paneles de administración o CMS headless (Sanity, Strapi, etc.) para que actualices textos, imágenes y posts del blog sin necesidad de programación.',
      },
    ]}
  />

  <CtaBanner />
</Layout>
