---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import MissionVision from '~/components/widgets/MissionVision.astro';
import WhyChoose from '~/components/widgets/WhyChoose.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

const metadata = {
  title: 'Nosotros — Equipo de desarrollo de software en Montería | Tache Technology',
  description:
    'Somos Tache Technology, startup tecnológica en Montería, Córdoba. Ganadores del Programa de Transformación Digital para MiPYMES. Conoce nuestra misión, visión y valores.',
};

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    url: 'https://tachetech.com/nosotros',
    name: 'Nosotros — Tache Technology',
    description:
      'Startup tecnológica en Montería. Desarrollo de software, páginas web y automatización para empresas.',
    mainEntity: { '@id': 'https://tachetech.com/#organization' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://tachetech.com/' },
      { '@type': 'ListItem', position: 2, name: 'Nosotros', item: 'https://tachetech.com/nosotros' },
    ],
  },
];
---

<Layout metadata={metadata} schemas={schemas}>
  <HeroPremium
    eyebrow="Sobre Tache Technology"
    title='Construimos tecnología <span class="text-[#1d0cdf]">cerca de ti</span>'
    subtitle="Somos un equipo apasionado por la tecnología y comprometido con cada proyecto. Trabajamos con cercanía, transparencia y enfoque en resultados reales para tu negocio."
    showCtas={false}
  />

  <MissionVision />

  <WhyChoose />

  <CtaBanner
    title="Conoce más sobre cómo trabajamos"
    subtitle="Agenda una conversación de 30 minutos sin costo. Sin tecnicismos, solo claridad sobre cómo podemos ayudarte."
    primaryText="Hablar con nosotros"
  />
</Layout>
