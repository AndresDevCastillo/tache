---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import ProjectsGrid from '~/components/widgets/ProjectsGrid.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

const metadata = {
  title: 'Proyectos y casos de éxito | Tache Technology Montería',
  description:
    'Casos reales de desarrollo de software, páginas web y automatización para empresas en Montería y Colombia. Conoce los resultados que hemos entregado.',
};

const projects = [
  {
    category: 'Logística',
    title: 'Optimización de entregas',
    problem: 'Procesos manuales y poco seguimiento de entregas generaban retrasos y errores.',
    solution: 'Plataforma web para organizar rutas, gestionar estados y llevar control operativo.',
    result: 'Mayor control interno, mejor seguimiento en tiempo real y menos tareas manuales.',
    icon: 'tabler:truck-delivery',
    accent: 'blue' as const,
  },
  {
    category: 'Inventario',
    title: 'Digitalización de inventario',
    problem: 'El inventario se manejaba con hojas de cálculo y registros manuales.',
    solution: 'Sistema web para registrar productos, movimientos y reportes automáticos.',
    result: 'Información organizada, mejor trazabilidad y menos errores operativos.',
    icon: 'tabler:box-seam',
    accent: 'indigo' as const,
  },
  {
    category: 'Salud',
    title: 'Telemedicina y citas',
    problem: 'La gestión de citas y pacientes se hacía de forma manual.',
    solution: 'Plataforma para agendamiento, pacientes y consultas en línea.',
    result: 'Mejor atención, organización y disponibilidad 24/7 para los usuarios.',
    icon: 'tabler:stethoscope',
    accent: 'cyan' as const,
  },
  {
    category: 'Comercio',
    title: 'Tienda online para distribuidora',
    problem: 'Solo vendían por WhatsApp: pedidos dispersos y proceso lento.',
    solution: 'Tienda en línea con catálogo, carrito y pagos integrados.',
    result: 'Triplicaron los pedidos en los primeros 3 meses de operación.',
    icon: 'tabler:building-store',
    accent: 'emerald' as const,
  },
  {
    category: 'Servicios',
    title: 'Asistente virtual 24/7',
    problem: 'El equipo no alcanzaba a responder todas las consultas fuera de horario.',
    solution: 'Bot inteligente para web y WhatsApp que responde preguntas frecuentes y deriva casos complejos.',
    result: 'Resuelve el 70% de las consultas sin intervención humana.',
    icon: 'tabler:message-chatbot',
    accent: 'amber' as const,
  },
  {
    category: 'Inmobiliaria',
    title: 'Catálogo de propiedades con búsqueda',
    problem: 'No tenían presencia digital y perdían leads calificados.',
    solution: 'Sitio web con catálogo dinámico, filtros y panel para cargar propiedades sin saber programar.',
    result: 'Más leads de calidad cada mes y una marca más fuerte en su mercado.',
    icon: 'tabler:home',
    accent: 'rose' as const,
  },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Proyectos y casos de éxito — Tache Technology',
    url: 'https://tachetech.com/proyectos',
    description:
      'Casos reales de desarrollo de software, páginas web y automatización entregados por Tache Technology en Montería.',
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: projects.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'CreativeWork',
          name: p.title,
          about: p.category,
          description: `${p.problem} ${p.solution} ${p.result}`,
        },
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://tachetech.com/' },
      { '@type': 'ListItem', position: 2, name: 'Proyectos', item: 'https://tachetech.com/proyectos' },
    ],
  },
];
---

<Layout metadata={metadata} schemas={schemas}>
  <HeroPremium
    eyebrow="Casos de éxito"
    title='Resultados reales para <span class="text-[#1d0cdf]">negocios reales</span>'
    subtitle="Cada proyecto que entregamos resuelve un problema concreto y deja a un negocio funcionando mejor. Aquí algunos ejemplos."
    showCtas={false}
  />

  <ProjectsGrid
    items={projects}
    eyebrow="Casos de Éxito"
    title="Proyectos entregados"
    subtitle="Historias reales de transformación digital en empresas de Montería, Córdoba y Colombia."
    variant="cases"
    showCta={false}
  />

  <CtaBanner
    title="¿Te imaginas tu proyecto aquí?"
    subtitle="Conversemos sobre lo que necesitas. Te ayudamos a darle forma y a llevarlo a la realidad."
    primaryText="Empezar mi proyecto"
  />
</Layout>
