---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import ProjectsGrid from '~/components/widgets/ProjectsGrid.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

const metadata = {
  title: 'Proyectos — Casos reales de Tache Technology',
  description:
    'Conoce algunos de los proyectos que hemos entregado: páginas web, aplicaciones a medida y automatizaciones para empresas de distintos sectores.',
};

// NOTA: estos son ejemplos demostrativos. Reemplaza con casos reales y enlaces
// a los sitios cuando los tengas. Mantener el formato (categoría/título/descripción
// /resultado) para consistencia visual.
const projects = [
  {
    category: 'Comercio',
    title: 'Tienda online para distribuidora local',
    description:
      'Diseñamos y lanzamos la tienda en línea de una distribuidora regional, con catálogo, carrito de compras y pagos integrados. Antes solo vendían por WhatsApp.',
    result: 'Triplicaron sus pedidos en los primeros 3 meses.',
    accent: 'indigo' as const,
    icon: 'tabler:building-store',
  },
  {
    category: 'Salud',
    title: 'Plataforma de citas para clínica dental',
    description:
      'Sistema web para que los pacientes agenden sus citas online y el equipo administre la agenda desde un panel sencillo. Incluye recordatorios automáticos.',
    result: 'Redujeron en 60% las inasistencias a citas.',
    accent: 'cyan' as const,
    icon: 'tabler:dental',
  },
  {
    category: 'Logística',
    title: 'Panel de seguimiento de envíos',
    description:
      'Aplicación web para que los clientes consulten en tiempo real el estado de sus envíos. La empresa dejó de recibir cientos de llamadas al día por consultas.',
    result: 'Liberaron al equipo para tareas de mayor valor.',
    accent: 'violet' as const,
    icon: 'tabler:truck-delivery',
  },
  {
    category: 'Educación',
    title: 'Sitio web institucional con blog',
    description:
      'Página web moderna para una institución educativa, con sección de noticias, calendario de eventos y formulario de inscripción a programas.',
    result: 'Aumentaron 40% las inscripciones online.',
    accent: 'emerald' as const,
    icon: 'tabler:school',
  },
  {
    category: 'Servicios',
    title: 'Asistente virtual para atención al cliente',
    description:
      'Bot inteligente que responde las preguntas frecuentes de los clientes 24/7 desde la web y WhatsApp, y deriva los casos complejos al equipo humano.',
    result: 'Resuelve el 70% de las consultas sin intervención.',
    accent: 'amber' as const,
    icon: 'tabler:message-chatbot',
  },
  {
    category: 'Inmobiliaria',
    title: 'Catálogo de propiedades con búsqueda',
    description:
      'Sitio web con catálogo dinámico, filtros por zona, precio y características, y panel administrativo para que el equipo cargue propiedades sin saber programar.',
    result: 'Más leads de calidad cada mes.',
    accent: 'rose' as const,
    icon: 'tabler:home',
  },
];
---

<Layout metadata={metadata}>
  <HeroPremium
    badge="Nuestros proyectos"
    title='Resultados reales para <span class="text-gradient">negocios reales</span>'
    subtitle="Cada proyecto que entregamos resuelve un problema concreto y deja a un negocio funcionando mejor. Aquí algunos ejemplos."
    showCtas={false}
  />

  <ProjectsGrid items={projects} />

  <CtaBanner
    title="¿Te imaginas tu proyecto aquí?"
    subtitle="Conversemos sobre lo que necesitas. Te ayudamos a darle forma y a llevarlo a la realidad."
    primaryText="Empezar mi proyecto"
  />
</Layout>
