---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import ContactFormPro from '~/components/widgets/ContactFormPro.astro';

const metadata = {
  title: 'Contacto — Hablemos de tu proyecto',
  description:
    'Solicita una asesoría, cotiza tu proyecto o escríbenos por WhatsApp. Respondemos en menos de 24 horas hábiles.',
};
---

<Layout metadata={metadata}>
  <HeroPremium
    title='Empecemos a construir <span class="text-gradient">algo grande juntos</span>'
    subtitle="Cuéntanos qué necesitas y te respondemos en menos de 24 horas hábiles. Si lo prefieres, escríbenos directo por WhatsApp y conversamos al instante."
    showCtas={false}
  />

  <ContactFormPro whatsappNumber="573013745541" />
</Layout>
