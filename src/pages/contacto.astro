---
import Layout from '~/layouts/PageLayout.astro';
import ContactFormPro from '~/components/widgets/ContactFormPro.astro';

const metadata = {
  title: 'Contacto — Hablemos de tu proyecto',
  description:
    'Solicita una asesoría, cotiza tu proyecto o escríbenos por WhatsApp. Respondemos en menos de 24 horas hábiles.',
};
---

<Layout metadata={metadata}>
  <!-- Hero compacto -->
  <section class="relative pt-32 md:pt-40 pb-4 overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-radial-spotlight"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-grid opacity-40"></div>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <span class="pill" data-reveal>
        <span class="dot"></span>
        Hablemos
      </span>
      <h1
        class="mt-5 text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-white"
        data-reveal
        data-reveal-delay="100"
      >
        Empecemos a construir <span class="text-gradient">algo grande juntos</span>
      </h1>
      <p class="mt-6 text-lg text-slate-300" data-reveal data-reveal-delay="200">
        Cuéntanos qué necesitas y te respondemos en menos de 24 horas hábiles. Si lo prefieres, escríbenos
        directo por WhatsApp y conversamos al instante.
      </p>
    </div>
  </section>

  <ContactFormPro whatsappNumber="573013745541" />
</Layout>
