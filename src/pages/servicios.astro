---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import ServicesGrid from '~/components/widgets/ServicesGrid.astro';
import TechStack from '~/components/widgets/TechStack.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

const metadata = {
  title: 'Servicios de desarrollo de software y automatización en Montería | Tache Technology',
  description:
    'Software a medida, páginas web, aplicaciones web, automatización, bots con IA, integraciones API, Linux & Cloud y consultoría para empresas en Montería y Colombia.',
};

const services = [
  {
    icon: 'tabler:code',
    title: 'Software a medida',
    description:
      'Sistemas personalizados para gestionar procesos, clientes, reportes, inventarios y operaciones.',
  },
  {
    icon: 'tabler:world',
    title: 'Páginas web profesionales',
    description:
      'Sitios modernos, rápidos y optimizados para captar clientes y fortalecer tu presencia digital.',
  },
  {
    icon: 'tabler:devices',
    title: 'Aplicaciones web',
    description:
      'Plataformas seguras y escalables para gestionar tu negocio desde cualquier lugar.',
  },
  {
    icon: 'tabler:bolt',
    title: 'Automatización',
    description:
      'Automatizamos tareas repetitivas conectando formularios, WhatsApp, correos, bases de datos y herramientas.',
  },
  {
    icon: 'tabler:robot',
    title: 'Bots con IA',
    description:
      'Asistentes inteligentes para atención al cliente, agendamiento, preguntas frecuentes y procesos comerciales.',
  },
  {
    icon: 'tabler:api',
    title: 'Integraciones API',
    description:
      'Conectamos sistemas, pagos, CRM, ERP, formularios, bases de datos y plataformas externas.',
  },
  {
    icon: 'tabler:cloud-computing',
    title: 'Linux & Cloud',
    description:
      'Configuramos servidores, dominios, SSL, despliegues, backups, bases de datos y aplicaciones en la nube.',
  },
  {
    icon: 'tabler:compass',
    title: 'Consultoría',
    description:
      'Te ayudamos a definir la mejor solución digital según tus objetivos, presupuesto y etapa del negocio.',
  },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'Desarrollo de software y automatización',
    provider: { '@id': 'https://tachetech.com/#organization' },
    areaServed: [
      { '@type': 'City', name: 'Montería' },
      { '@type': 'State', name: 'Córdoba' },
      { '@type': 'Country', name: 'Colombia' },
    ],
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Servicios Tache Technology',
      itemListElement: services.map((s) => ({
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: s.title,
          description: s.description,
        },
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://tachetech.com/' },
      { '@type': 'ListItem', position: 2, name: 'Servicios', item: 'https://tachetech.com/servicios' },
    ],
  },
];
---

<Layout metadata={metadata} schemas={schemas}>
  <HeroPremium
    eyebrow="Catálogo completo"
    title='Tecnología que <span class="text-[#1d0cdf]">resuelve problemas</span> reales'
    subtitle="Cada servicio está orientado a un resultado de negocio: más ventas, menos costos, procesos automatizados o un producto digital que crece contigo."
    showCtas={false}
  />

  <ServicesGrid
    id="catalogo"
    eyebrow="Catálogo completo"
    title="Todo lo que necesitas para crecer en digital"
    subtitle="Desde tu primera página web hasta sistemas completos a medida. Trabajamos como tu socio tecnológico de largo plazo."
    items={services}
    fourCols={true}
    cardCta="Conocer más"
  />

  <TechStack />

  <CtaBanner
    title="¿No estás seguro qué necesitas?"
    subtitle="Te ayudamos a entenderlo en una conversación de 30 minutos sin costo. Salimos con un plan claro y los siguientes pasos definidos."
  />
</Layout>
