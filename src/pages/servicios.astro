---
import Layout from '~/layouts/PageLayout.astro';
import ServicesGrid from '~/components/widgets/ServicesGrid.astro';
import ContactFormPro from '~/components/widgets/ContactFormPro.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

const metadata = {
  title: 'Servicios — Software a medida, IA y Cloud',
  description:
    'Desarrollo web, aplicaciones a medida, automatización con IA, integraciones, cloud y DevOps. Conoce todos los servicios de Tache Technology.',
};

const services = [
  {
    icon: 'tabler:device-desktop-code',
    title: 'Desarrollo de páginas web',
    description:
      'Sitios corporativos, landings y e-commerce optimizados para velocidad, SEO y conversión. Tecnología moderna (Astro, Next.js) con CMS opcional.',
    benefit: 'Más visibilidad y leads desde el primer mes.',
    gradient: 'bg-gradient-to-br from-indigo-500 to-violet-600',
  },
  {
    icon: 'tabler:apps',
    title: 'Aplicaciones web personalizadas',
    description:
      'Plataformas SaaS, dashboards, CRMs y portales internos a medida. Stack: Next.js, NestJS, PostgreSQL, autenticación segura y roles.',
    benefit: 'Procesos digitalizados que escalan con tu equipo.',
    gradient: 'bg-gradient-to-br from-violet-500 to-fuchsia-600',
  },
  {
    icon: 'tabler:robot',
    title: 'Automatización con IA',
    description:
      'Chatbots inteligentes, agentes de IA, análisis de documentos, generación de contenido y workflows con modelos LLM (OpenAI, Anthropic).',
    benefit: 'Hasta 70% menos tiempo en tareas operativas.',
    gradient: 'bg-gradient-to-br from-cyan-500 to-blue-600',
  },
  {
    icon: 'tabler:plug-connected',
    title: 'Integraciones y APIs',
    description:
      'Conectamos tus herramientas existentes: ERPs, CRMs, pasarelas de pago (Wompi, Mercado Pago, Stripe), facturación electrónica DIAN y WhatsApp Business.',
    benefit: 'Tu stack hablando entre sí, sin trabajo manual.',
    gradient: 'bg-gradient-to-br from-blue-500 to-indigo-600',
  },
  {
    icon: 'tabler:cloud-cog',
    title: 'Cloud y DevOps',
    description:
      'Despliegues automatizados (CI/CD), infraestructura como código, monitoreo y alertas. AWS, GCP, DigitalOcean o tu VPS propio.',
    benefit: 'Uptime profesional y costos cloud bajo control.',
    gradient: 'bg-gradient-to-br from-emerald-500 to-cyan-600',
  },
  {
    icon: 'tabler:database',
    title: 'Bases de datos y backend',
    description:
      'Diseño de bases de datos relacionales y NoSQL, APIs REST y GraphQL, optimización de queries y backups automáticos.',
    benefit: 'Datos seguros, accesibles y rápidos.',
    gradient: 'bg-gradient-to-br from-amber-500 to-orange-600',
  },
  {
    icon: 'tabler:server-cog',
    title: 'Administración de servidores Linux',
    description:
      'Configuración, securización y mantenimiento de servidores Linux. Hardening, firewalls, certificados SSL y backups automatizados.',
    benefit: 'Servidores seguros y disponibles 24/7.',
    gradient: 'bg-gradient-to-br from-rose-500 to-pink-600',
  },
  {
    icon: 'tabler:briefcase',
    title: 'Consultoría tecnológica',
    description:
      'Auditoría de tu stack actual, recomendaciones de arquitectura, selección de tecnologías y planificación de migraciones.',
    benefit: 'Decisiones técnicas con visión de negocio.',
    gradient: 'bg-gradient-to-br from-teal-500 to-emerald-600',
  },
  {
    icon: 'tabler:tools',
    title: 'Soporte y evolución continua',
    description:
      'Mantenimiento mensual, nuevas funcionalidades, mejoras de performance y respuesta rápida ante incidencias.',
    benefit: 'Un equipo técnico disponible cuando lo necesites.',
    gradient: 'bg-gradient-to-br from-fuchsia-500 to-pink-600',
  },
];
---

<Layout metadata={metadata}>
  <!-- Hero compacto -->
  <section class="relative pt-32 md:pt-40 pb-8 overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-radial-spotlight"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-grid opacity-40"></div>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <span class="pill" data-reveal>
        <span class="dot"></span>
        Nuestros servicios
      </span>
      <h1
        class="mt-5 text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-white"
        data-reveal
        data-reveal-delay="100"
      >
        Tecnología que <span class="text-gradient">resuelve problemas reales</span> de tu negocio
      </h1>
      <p class="mt-6 text-lg text-slate-300" data-reveal data-reveal-delay="200">
        Cada servicio está orientado a un resultado de negocio: más ventas, menos costos, procesos
        automatizados o un producto digital que escale con tu crecimiento.
      </p>
    </div>
  </section>

  <ServicesGrid
    id="catalogo"
    tagline="Catálogo completo"
    title="Servicios end-to-end para tu transformación digital"
    subtitle="Desde la primera idea hasta la operación en producción. Trabajamos como tu socio tecnológico, no como un proveedor más."
    items={services}
  />

  <ContactFormPro whatsappNumber="573013745541" />

  <CtaBanner
    title="¿No estás seguro qué necesitas?"
    subtitle="Te ayudamos a diagnosticar tu situación en 30 minutos sin costo. Salimos con un plan claro y los siguientes pasos definidos."
  />
</Layout>
