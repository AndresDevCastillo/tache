---
import Layout from '~/layouts/PageLayout.astro';
import HeroPremium from '~/components/widgets/HeroPremium.astro';
import ServicesGrid from '~/components/widgets/ServicesGrid.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

const metadata = {
  title: 'Servicios — Soluciones digitales para tu negocio',
  description:
    'Páginas web, aplicaciones a medida, automatización inteligente, integraciones y más. Conoce todos los servicios de Tache Technology.',
};

const services = [
  {
    icon: 'tabler:world',
    title: 'Páginas web profesionales',
    description:
      'Sitios web modernos y rápidos que se ven perfectos en cualquier dispositivo. Optimizados para que aparezcas en Google y conviertas visitantes en clientes.',
  },
  {
    icon: 'tabler:building-store',
    title: 'Tiendas online',
    description:
      'Vende por internet con catálogo de productos, carrito de compras y pagos en línea. Listo para que tus clientes compren cuando quieran, desde donde estén.',
  },
  {
    icon: 'tabler:layout-grid',
    title: 'Aplicaciones a la medida',
    description:
      'Plataformas hechas para tu negocio: gestiona clientes, inventario, equipos o proyectos desde un solo lugar, con la información que tú necesitas.',
  },
  {
    icon: 'tabler:sparkles',
    title: 'Automatización inteligente',
    description:
      'Asistentes virtuales y procesos automáticos que se encargan de tareas repetitivas. Tu equipo gana horas para enfocarse en lo que realmente importa.',
  },
  {
    icon: 'tabler:link',
    title: 'Integraciones entre sistemas',
    description:
      'Conectamos las herramientas que ya usas (pagos, facturación, WhatsApp, redes sociales) para que trabajen juntas y dejes de hacer todo a mano.',
  },
  {
    icon: 'tabler:cloud',
    title: 'Tu sistema siempre disponible',
    description:
      'Hacemos que tu plataforma esté siempre en línea, segura y rápida, sin caídas ni dolores de cabeza. Tú te enfocas en tu negocio.',
  },
  {
    icon: 'tabler:shield-check',
    title: 'Seguridad y respaldo',
    description:
      'Protegemos tu información y la de tus clientes con copias de seguridad automáticas y prácticas que evitan ataques. Duermes tranquilo.',
  },
  {
    icon: 'tabler:briefcase',
    title: 'Asesoría tecnológica',
    description:
      'Te ayudamos a tomar decisiones inteligentes sobre tecnología, sin tecnicismos. Te decimos qué necesitas, qué no y por qué.',
  },
  {
    icon: 'tabler:headset',
    title: 'Soporte continuo',
    description:
      'Después de entregar tu proyecto seguimos contigo: mantenimiento, mejoras, nuevas funciones y respuesta rápida cuando nos necesites.',
  },
];
---

<Layout metadata={metadata}>
  <HeroPremium
    badge="Nuestros servicios"
    title='Tecnología que <span class="text-gradient">resuelve problemas</span> reales'
    subtitle="Cada servicio está orientado a un resultado de negocio: más ventas, menos costos, procesos automatizados o un producto digital que crece contigo."
    showCtas={false}
  />

  <ServicesGrid
    id="catalogo"
    tagline="Catálogo completo"
    title="Todo lo que necesitas para crecer en digital"
    subtitle="Desde tu primera página web hasta sistemas completos a medida. Trabajamos como tu socio tecnológico de largo plazo."
    items={services}
    cardCta=""
  />

  <CtaBanner
    title="¿No estás seguro qué necesitas?"
    subtitle="Te ayudamos a entenderlo en una conversación de 30 minutos sin costo. Salimos con un plan claro y los siguientes pasos definidos."
  />
</Layout>
