{
  "name": "tachetech-backend",
  "version": "1.0.0",
  "description": "API NestJS para tachetech.com — formulario de contacto, email y futuras integraciones.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
