# ==========================================================================
# Tache Technology — API NestJS · variables de entorno
# Copiar este archivo a `.env` y completar con valores reales.
# NUNCA commitear `.env` (ya está en .gitignore).
# ==========================================================================

# --- Server ---
PORT=3001
NODE_ENV=production

# --- CORS ---
# Lista CSV de orígenes autorizados (sin barra final).
# Producción típica: solo el dominio del frontend.
CORS_ORIGINS=https://tachetech.com,https://www.tachetech.com

# --- Rate limiting (anti-spam global) ---
# Ventana en milisegundos y máximo de peticiones por IP.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=20

# --- SMTP (envío de emails) ---
# Si CUALQUIERA de estas falta, el servicio entra en DRY-RUN
# (loguea el email pero no lo envía). Útil para desarrollo.
#
# Ejemplos de proveedores comunes:
#   Hostinger:  smtp.hostinger.com    · puerto 465 secure=true
#   Zoho:       smtp.zoho.com         · puerto 465 secure=true
#   Gmail:      smtp.gmail.com        · puerto 587 secure=false (requiere App Password)
#   SendGrid:   smtp.sendgrid.net     · puerto 587 secure=false (user="apikey")
#   Brevo:      smtp-relay.brevo.com  · puerto 587 secure=false
#   Resend:     smtp.resend.com       · puerto 465 secure=true (user="resend")
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Direcciones ---
# Remitente que verán los destinatarios. Tiene que coincidir con un dominio
# autorizado por tu proveedor SMTP (idealmente un alias en tachetech.com).
MAIL_FROM="Tache Technology <no-reply@tachetech.com>"

# A dónde llegan los leads del formulario.
MAIL_TO=contacto@tachetech.com

# --- WhatsApp ---
# Número internacional sin '+' ni espacios (ej: 573013745541).
# Se usa para componer la URL wa.me que se devuelve al cliente.
WHATSAPP_NUMBER=573013745541
